{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "Skill",
      "mcp__*",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo:*)"
    ]
  },
  "env": {
    "KAGAMI_MODE": "production",
    "KAGAMI_ENV": "production",
    "KAGAMI_ENABLE_SELF_MODIFICATION": "0"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.hermes/hooks/hermes-session-init.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.hermes/hooks/hermes-prompt.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.hermes/hooks/hermes-session-end.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.hermes/hooks/hermes-cbf.sh",
            "timeout": 1
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.hermes/hooks/hermes-post-write.sh",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": []
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.hermes/hooks/hermes-session-end.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": []
      }
    ]
  }
}