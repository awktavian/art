{
  "$schema": "./schema/visual-regression.schema.json",
  "version": "1.0.0",
  "name": "kagami-visual-regression",
  "description": "AI-enhanced visual regression testing for Kagami cross-platform apps",

  "platforms": {
    "ios": {
      "enabled": true,
      "devices": ["iPhone 16 Pro", "iPad Pro 13"],
      "threshold": 0.01,
      "ai_analysis": true
    },
    "android": {
      "enabled": true,
      "devices": ["Pixel 8", "Galaxy S24"],
      "threshold": 0.01,
      "ai_analysis": true
    },
    "desktop": {
      "enabled": true,
      "variants": ["macos", "linux", "windows"],
      "threshold": 0.005,
      "ai_analysis": true
    },
    "tvos": {
      "enabled": true,
      "devices": ["Apple TV 4K"],
      "threshold": 0.02,
      "ai_analysis": true
    },
    "watchos": {
      "enabled": true,
      "devices": ["Apple Watch Series 10 45mm"],
      "threshold": 0.02,
      "ai_analysis": true
    },
    "visionos": {
      "enabled": true,
      "devices": ["Apple Vision Pro"],
      "threshold": 0.03,
      "ai_analysis": true
    }
  },

  "paths": {
    "baselines": "baselines/",
    "current": "current/",
    "diffs": "diffs/",
    "reports": "reports/",
    "ai_analysis": "ai_analysis/"
  },

  "ai_config": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-20250514",
    "analysis_types": [
      "semantic_diff",
      "accessibility_check",
      "design_system_compliance",
      "regression_classification"
    ],
    "batch_size": 10,
    "cache_analysis": true
  },

  "thresholds": {
    "pixel_diff_percent": 0.01,
    "structural_similarity": 0.95,
    "perceptual_hash_distance": 8,
    "ai_confidence_threshold": 0.8
  },

  "notifications": {
    "slack_webhook": "${SLACK_VISUAL_REGRESSION_WEBHOOK}",
    "github_comment": true,
    "artifact_retention_days": 30
  },

  "ignore_regions": {
    "global": [
      { "type": "timestamp", "pattern": "\\d{1,2}:\\d{2}(:\\d{2})?" },
      { "type": "dynamic_content", "css_selector": "[data-testid='loading']" }
    ],
    "per_platform": {
      "ios": [{ "type": "status_bar", "region": { "top": 0, "height": 54 } }],
      "android": [{ "type": "status_bar", "region": { "top": 0, "height": 24 } }]
    }
  }
}
