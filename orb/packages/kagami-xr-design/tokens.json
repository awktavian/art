{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "name": "Kagami XR Design System Tokens",
  "description": "Unified design tokens for cross-platform XR/AR development across Meta Quest, Meta Ray-Ban, Apple Vision Pro, AndroidXR, and WebXR",

  "platforms": {
    "meta_quest": {
      "id": "meta_quest",
      "name": "Meta Quest / Horizon OS",
      "type": "mr_headset",
      "devices": ["Quest 3", "Quest 3S", "Quest Pro"],
      "sdk": "Meta Spatial SDK",
      "field_of_view": {
        "horizontal_deg": 110,
        "vertical_deg": 96
      },
      "display": {
        "resolution_per_eye": [2064, 2208],
        "refresh_rates_hz": [72, 90, 120],
        "pixels_per_degree": 25
      },
      "input_modalities": ["controllers", "hand_tracking", "eye_tracking", "voice"],
      "passthrough": true,
      "spatial_anchors": true
    },
    "meta_rayban": {
      "id": "meta_rayban",
      "name": "Meta Ray-Ban Smart Glasses",
      "type": "ar_glasses",
      "devices": ["Ray-Ban Meta", "Ray-Ban Display"],
      "sdk": "Meta AR SDK",
      "field_of_view": {
        "horizontal_deg": 20,
        "vertical_deg": 20
      },
      "display": {
        "resolution": [600, 600],
        "brightness_nits": 5000,
        "pixels_per_degree": 42
      },
      "input_modalities": ["neural_band", "touch", "voice", "camera_ai"],
      "passthrough": true,
      "spatial_anchors": false,
      "notes": "Designed for glanceable, short interactions"
    },
    "apple_vision_pro": {
      "id": "apple_vision_pro",
      "name": "Apple Vision Pro",
      "type": "spatial_computer",
      "devices": ["Vision Pro", "Vision Pro (M5)"],
      "sdk": "visionOS SDK",
      "field_of_view": {
        "horizontal_deg": 100,
        "vertical_deg": 90
      },
      "display": {
        "resolution_per_eye": [3660, 3200],
        "refresh_rates_hz": [90, 96, 100],
        "pixels_per_degree": 34
      },
      "input_modalities": ["eye_tracking", "hand_gestures", "voice", "external_controllers"],
      "passthrough": true,
      "spatial_anchors": true,
      "frameworks": ["SwiftUI", "RealityKit", "ARKit"]
    },
    "android_xr": {
      "id": "android_xr",
      "name": "Android XR",
      "type": "mr_headset",
      "devices": ["Samsung Galaxy XR", "Xreal AR Glasses"],
      "sdk": "Android XR SDK",
      "field_of_view": {
        "horizontal_deg": 110,
        "vertical_deg": 95
      },
      "display": {
        "resolution_per_eye": [2480, 2480],
        "refresh_rates_hz": [90, 120],
        "pixels_per_degree": 30
      },
      "input_modalities": ["hand_tracking", "eye_tracking", "voice", "controllers"],
      "passthrough": true,
      "spatial_anchors": true,
      "ai_integration": "gemini",
      "frameworks": ["Jetpack Compose XR", "ARCore", "Unity", "Unreal"]
    },
    "webxr": {
      "id": "webxr",
      "name": "WebXR",
      "type": "web_standard",
      "devices": ["All WebXR-compatible browsers"],
      "sdk": "WebXR Device API",
      "session_modes": ["inline", "immersive-vr", "immersive-ar"],
      "input_modalities": ["controllers", "hand_tracking", "gaze"],
      "passthrough": "device_dependent",
      "spatial_anchors": "device_dependent",
      "frameworks": ["Three.js", "A-Frame", "Babylon.js", "PlayCanvas"]
    }
  },

  "proxemic_zones": {
    "description": "Hall's proxemic theory adapted for XR spatial computing",
    "intimate": {
      "range_m": [0, 0.45],
      "range_ft": [0, 1.5],
      "use_cases": ["personal_ui", "private_data", "focus_elements"],
      "interaction_style": "direct_manipulation",
      "privacy_level": "high",
      "notes": "Reserved for highly personal content. Social XR should prevent uninvited entry."
    },
    "personal": {
      "range_m": [0.45, 1.2],
      "range_ft": [1.5, 4],
      "use_cases": ["primary_workspace", "interactive_objects", "menus"],
      "interaction_style": "hand_reach",
      "privacy_level": "medium",
      "notes": "Primary interaction zone. Optimal for hand manipulation."
    },
    "social": {
      "range_m": [1.2, 3.6],
      "range_ft": [4, 12],
      "use_cases": ["shared_content", "collaboration", "environment_objects"],
      "interaction_style": "ray_pointing",
      "privacy_level": "low",
      "notes": "Ray-based interaction. Suitable for shared and collaborative elements."
    },
    "public": {
      "range_m": [3.6, null],
      "range_ft": [12, null],
      "use_cases": ["environment", "ambient_info", "navigation_landmarks"],
      "interaction_style": "gaze_voice",
      "privacy_level": "none",
      "notes": "Background and ambient content. Teleportation targets."
    },
    "optimal_content_zone": {
      "min_m": 1.25,
      "max_m": 5.0,
      "description": "Recommended zone for primary AR content placement"
    }
  },

  "viewing_angles": {
    "description": "Comfortable viewing angle constraints based on human ergonomics",
    "horizontal": {
      "optimal_deg": 30,
      "comfortable_deg": 50,
      "maximum_deg": 70,
      "notes": "Content beyond 30deg requires neck movement; beyond 50deg is strenuous"
    },
    "vertical": {
      "optimal_up_deg": 15,
      "comfortable_up_deg": 25,
      "maximum_up_deg": 35,
      "optimal_down_deg": 20,
      "comfortable_down_deg": 40,
      "maximum_down_deg": 60,
      "notes": "Downward viewing is more comfortable than upward"
    },
    "depth_of_field": {
      "near_focus_m": 0.5,
      "comfortable_focus_m": 2.0,
      "vergence_accommodation_notes": "Minimize conflict by keeping content between 1.25m - 5m"
    }
  },

  "input_modalities": {
    "hand_tracking": {
      "gestures": {
        "pinch": {
          "description": "Thumb and index finger touch",
          "use_cases": ["select", "confirm", "grab"],
          "platforms": ["meta_quest", "apple_vision_pro", "android_xr", "webxr"]
        },
        "poke": {
          "description": "Direct touch with index finger",
          "use_cases": ["button_press", "ui_interaction"],
          "platforms": ["meta_quest", "apple_vision_pro", "android_xr"]
        },
        "grab": {
          "description": "Close hand to grab object",
          "use_cases": ["object_manipulation", "move", "resize"],
          "platforms": ["meta_quest", "apple_vision_pro", "android_xr", "webxr"]
        },
        "palm_open": {
          "description": "Open palm facing forward",
          "use_cases": ["menu_summon", "stop", "release"],
          "platforms": ["meta_quest", "apple_vision_pro", "android_xr"]
        },
        "thumbs_up": {
          "description": "Thumb extended upward",
          "use_cases": ["confirm", "like", "positive_feedback"],
          "platforms": ["meta_quest", "android_xr"]
        },
        "two_hand_scale": {
          "description": "Both hands pinching and moving apart/together",
          "use_cases": ["scale_object", "zoom"],
          "platforms": ["meta_quest", "apple_vision_pro", "android_xr"]
        }
      },
      "design_guidelines": {
        "feedback_required": true,
        "hover_state_distance_m": 0.1,
        "grab_threshold_m": 0.05,
        "minimum_target_size_m": 0.044
      }
    },
    "eye_tracking": {
      "gaze_behaviors": {
        "dwell": {
          "description": "Sustained gaze on target",
          "typical_duration_ms": 800,
          "use_cases": ["selection", "activation"]
        },
        "glance": {
          "description": "Brief look at target",
          "typical_duration_ms": 200,
          "use_cases": ["preview", "hover"]
        },
        "saccade": {
          "description": "Rapid eye movement between targets",
          "use_cases": ["navigation", "scanning"]
        }
      },
      "design_guidelines": {
        "gaze_target_min_size_deg": 1.0,
        "gaze_target_recommended_size_deg": 2.0,
        "avoid_gaze_only_activation": true,
        "combine_with_gesture": "pinch",
        "notes": "Apple Vision Pro uses eye+pinch as primary selection. Never use gaze-only for critical actions."
      },
      "platforms": ["meta_quest", "apple_vision_pro", "android_xr"]
    },
    "neural_band": {
      "description": "Meta Neural Band EMG wristband input",
      "technology": "Surface Electromyography (sEMG)",
      "gestures": {
        "click": {
          "description": "Subtle finger tap gesture",
          "use_cases": ["select", "confirm"]
        },
        "swipe": {
          "description": "Finger swipe motion",
          "use_cases": ["scroll", "navigate"]
        },
        "pinch": {
          "description": "Thumb to finger pinch",
          "use_cases": ["grab", "zoom"]
        },
        "draw": {
          "description": "Finger drawing on any surface",
          "use_cases": ["text_input", "handwriting"]
        }
      },
      "design_guidelines": {
        "processing": "on_device",
        "calibration_required": false,
        "privacy": "raw_emg_stays_on_device",
        "pair_with": "meta_rayban"
      },
      "platforms": ["meta_rayban"]
    },
    "controllers": {
      "types": {
        "6dof": {
          "description": "Full 6 degrees of freedom tracking",
          "platforms": ["meta_quest", "android_xr", "webxr"]
        },
        "playstation_vr2_sense": {
          "description": "PS VR2 controller support in visionOS 26",
          "features": ["6dof", "finger_touch", "haptics"],
          "platforms": ["apple_vision_pro"]
        }
      },
      "standard_bindings": {
        "trigger": ["select", "grab"],
        "grip": ["context_menu", "secondary_grab"],
        "thumbstick": ["locomotion", "scroll"],
        "button_a": ["confirm", "jump"],
        "button_b": ["back", "cancel"]
      }
    },
    "voice": {
      "wake_words": {
        "meta": ["Hey Meta"],
        "apple": ["Siri"],
        "android": ["Hey Google", "OK Google"]
      },
      "command_types": {
        "navigation": ["go to", "open", "show"],
        "control": ["pause", "play", "stop", "mute"],
        "query": ["what is", "how do I", "tell me about"],
        "action": ["take photo", "start recording", "send message"]
      },
      "design_guidelines": {
        "confirmation_required": true,
        "visual_feedback": true,
        "ambient_noise_handling": true
      },
      "platforms": ["meta_quest", "meta_rayban", "apple_vision_pro", "android_xr"]
    }
  },

  "haptic_patterns": {
    "description": "Standardized haptic feedback patterns for XR interactions",
    "intensity_levels": {
      "subtle": 0.25,
      "light": 0.5,
      "medium": 0.75,
      "strong": 1.0
    },
    "patterns": {
      "confirm": {
        "description": "Successful action confirmation",
        "pattern": [
          {"duration_ms": 50, "intensity": 0.6}
        ],
        "frequency_hz": 200
      },
      "error": {
        "description": "Error or invalid action",
        "pattern": [
          {"duration_ms": 100, "intensity": 0.8},
          {"pause_ms": 50},
          {"duration_ms": 100, "intensity": 0.8}
        ],
        "frequency_hz": 150
      },
      "hover": {
        "description": "Entering interactive element",
        "pattern": [
          {"duration_ms": 20, "intensity": 0.3}
        ],
        "frequency_hz": 250
      },
      "grab": {
        "description": "Grabbing an object",
        "pattern": [
          {"duration_ms": 30, "intensity": 0.5},
          {"duration_ms": 70, "intensity": 0.7, "ramp": "up"}
        ],
        "frequency_hz": 180
      },
      "release": {
        "description": "Releasing an object",
        "pattern": [
          {"duration_ms": 50, "intensity": 0.6, "ramp": "down"}
        ],
        "frequency_hz": 180
      },
      "scroll_tick": {
        "description": "Scroll detent feedback",
        "pattern": [
          {"duration_ms": 10, "intensity": 0.2}
        ],
        "frequency_hz": 220
      },
      "notification": {
        "description": "Attention-getting notification",
        "pattern": [
          {"duration_ms": 80, "intensity": 0.5},
          {"pause_ms": 100},
          {"duration_ms": 80, "intensity": 0.5},
          {"pause_ms": 100},
          {"duration_ms": 80, "intensity": 0.5}
        ],
        "frequency_hz": 200
      },
      "texture_smooth": {
        "description": "Smooth surface texture",
        "pattern": [
          {"duration_ms": 20, "intensity": 0.1, "repeat": true}
        ],
        "frequency_hz": 300
      },
      "texture_rough": {
        "description": "Rough surface texture",
        "pattern": [
          {"duration_ms": 10, "intensity": 0.4},
          {"pause_ms": 5}
        ],
        "frequency_hz": 150,
        "repeat": true
      }
    },
    "wrist_haptics": {
      "description": "Meta Neural Band wrist haptic patterns",
      "squeeze": {
        "use_cases": ["grab_feedback", "weight_simulation"],
        "intensity_range": [0.1, 1.0]
      },
      "vibrotactile": {
        "use_cases": ["notification", "confirmation", "texture"],
        "frequency_range_hz": [50, 300]
      }
    },
    "design_guidelines": {
      "make_optional": true,
      "allow_intensity_adjustment": true,
      "maintain_consistency": true,
      "respect_system_settings": true,
      "avoid_overuse": true
    }
  },

  "spatial_audio": {
    "description": "3D audio design tokens for immersive XR experiences",
    "hrtf": {
      "description": "Head-Related Transfer Function for 3D audio spatialization",
      "personalization": {
        "universal": "Use platform-provided universal HRTF",
        "personalized": "Platform-specific ear scanning when available"
      },
      "head_tracking": {
        "required": true,
        "latency_max_ms": 20,
        "notes": "Audio must update within 20ms of head movement"
      }
    },
    "audio_zones": {
      "intimate": {
        "distance_m": [0, 0.5],
        "behavior": "mono_centered",
        "volume_db": 0
      },
      "personal": {
        "distance_m": [0.5, 2.0],
        "behavior": "full_spatialization",
        "volume_db": 0
      },
      "social": {
        "distance_m": [2.0, 10.0],
        "behavior": "distance_attenuation",
        "attenuation_db_per_m": -3
      },
      "ambient": {
        "distance_m": [10.0, null],
        "behavior": "environmental",
        "reverb": true
      }
    },
    "reverb_presets": {
      "passthrough_ar": {
        "description": "Match real environment acoustics",
        "use_scene_mesh": true
      },
      "small_room": {
        "rt60_ms": 300,
        "early_reflections": true
      },
      "large_hall": {
        "rt60_ms": 1500,
        "early_reflections": true
      },
      "outdoor": {
        "rt60_ms": 100,
        "early_reflections": false
      }
    },
    "ui_sounds": {
      "volume_relative_db": -6,
      "spatialization": "head_locked",
      "notes": "UI sounds should be slightly quieter than world sounds"
    },
    "formats": {
      "supported": ["stereo", "ambisonics", "object_based", "dolby_atmos"],
      "recommended": "object_based"
    }
  },

  "display_modes": {
    "immersive_vr": {
      "description": "Fully immersive virtual environment",
      "passthrough": false,
      "world_anchored": true,
      "use_cases": ["games", "virtual_environments", "training"],
      "platforms": ["meta_quest", "apple_vision_pro", "android_xr", "webxr"]
    },
    "passthrough_ar": {
      "description": "Virtual content overlaid on real world",
      "passthrough": true,
      "world_anchored": true,
      "use_cases": ["productivity", "navigation", "assistance"],
      "platforms": ["meta_quest", "apple_vision_pro", "android_xr", "webxr"]
    },
    "window_2d": {
      "description": "Flat 2D window floating in space",
      "passthrough": true,
      "world_anchored": true,
      "use_cases": ["apps", "video", "browsing"],
      "platforms": ["meta_quest", "apple_vision_pro", "android_xr"]
    },
    "volume_3d": {
      "description": "3D volumetric content viewable from any angle",
      "passthrough": true,
      "world_anchored": true,
      "use_cases": ["3d_models", "data_visualization", "art"],
      "platforms": ["apple_vision_pro", "meta_quest", "android_xr"]
    },
    "hud_glanceable": {
      "description": "Small display for quick information glances",
      "passthrough": true,
      "world_anchored": false,
      "use_cases": ["notifications", "navigation", "status"],
      "platforms": ["meta_rayban"],
      "design_guidelines": {
        "interaction_duration_max_s": 10,
        "prefer_voice_input": true,
        "minimal_visual_clutter": true
      }
    }
  },

  "ui_components": {
    "panels": {
      "description": "Flat UI surfaces for traditional interfaces",
      "corner_radius_m": 0.02,
      "depth_offset_m": 0.001,
      "shadow": {
        "offset_m": 0.005,
        "blur_m": 0.01,
        "opacity": 0.3
      },
      "sizes": {
        "small": {"width_m": 0.3, "height_m": 0.2},
        "medium": {"width_m": 0.6, "height_m": 0.4},
        "large": {"width_m": 1.0, "height_m": 0.7},
        "fullscreen": {"width_m": 2.0, "height_m": 1.2}
      }
    },
    "buttons": {
      "min_size_m": 0.044,
      "recommended_size_m": 0.06,
      "depth_m": 0.008,
      "press_depth_m": 0.004,
      "states": {
        "default": {"opacity": 1.0},
        "hover": {"scale": 1.05, "glow": true},
        "pressed": {"depth_offset_m": -0.004, "opacity": 0.9},
        "disabled": {"opacity": 0.5}
      }
    },
    "sliders": {
      "track_height_m": 0.01,
      "thumb_diameter_m": 0.03,
      "grab_zone_m": 0.05
    },
    "tooltips": {
      "distance_m": 0.1,
      "delay_ms": 500,
      "fade_duration_ms": 150
    }
  },

  "animation_timing": {
    "description": "Fibonacci-based timing for natural motion",
    "fibonacci_ms": [89, 144, 233, 377, 610, 987],
    "presets": {
      "instant": 89,
      "fast": 144,
      "normal": 233,
      "slow": 377,
      "dramatic": 610,
      "cinematic": 987
    },
    "easing": {
      "entrance": "ease-out",
      "exit": "ease-in",
      "move": "ease-in-out",
      "spring": {
        "stiffness": 300,
        "damping": 30
      }
    },
    "spatial_considerations": {
      "max_velocity_m_per_s": 5.0,
      "avoid_sudden_movements": true,
      "maintain_depth_consistency": true,
      "notes": "Fast movements can cause discomfort. Keep content in view during transitions."
    }
  },

  "comfort_guidelines": {
    "locomotion": {
      "teleportation": {
        "fade_duration_ms": 150,
        "recommended": true
      },
      "smooth_locomotion": {
        "max_speed_m_per_s": 3.0,
        "acceleration_curve": "ease_in_out",
        "vignette_on_motion": true
      },
      "rotation": {
        "snap_rotation_deg": 30,
        "smooth_rotation_max_deg_per_s": 90
      }
    },
    "content_placement": {
      "avoid_floor_content": true,
      "avoid_ceiling_content": true,
      "prefer_eye_level": true,
      "maintain_horizon": true
    },
    "session_duration": {
      "reminder_interval_min": 30,
      "max_recommended_min": 120,
      "break_duration_min": 10
    },
    "accessibility": {
      "text_min_height_m": 0.01,
      "contrast_ratio_min": 4.5,
      "motion_reduction_option": true,
      "one_handed_operation": true,
      "voice_alternative": true
    }
  },

  "safety": {
    "guardian_boundary": {
      "description": "Virtual safety boundary around play area",
      "platforms": ["meta_quest", "android_xr"],
      "warning_distance_m": 0.5,
      "passthrough_activation_m": 0.3
    },
    "social_safety": {
      "personal_space_bubble_m": 0.45,
      "consent_for_proximity": true,
      "block_intimate_zone_entry": true
    },
    "eye_strain_prevention": {
      "focus_distance_optimal_m": 2.0,
      "blue_light_filter": true,
      "brightness_auto_adjust": true
    },
    "privacy_indicators": {
      "recording_led": true,
      "camera_active_indicator": true,
      "microphone_active_indicator": true
    }
  },

  "cross_platform_considerations": {
    "graceful_degradation": {
      "description": "Fallback strategies when features unavailable",
      "hand_tracking_fallback": "controllers",
      "eye_tracking_fallback": "head_gaze",
      "spatial_audio_fallback": "stereo",
      "haptics_fallback": "visual_feedback"
    },
    "feature_detection": {
      "check_before_use": true,
      "progressive_enhancement": true
    },
    "shared_experiences": {
      "cross_platform_avatars": true,
      "synchronized_spatial_anchors": true,
      "voice_chat": true
    }
  }
}
