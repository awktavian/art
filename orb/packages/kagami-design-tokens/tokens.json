{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Kagami Design System",
  "version": "2.0.0",
  "description": "Unified design tokens for all Kagami platforms",

  "colors": {
    "void": {
      "description": "Void Palette (Backgrounds)",
      "void": { "hex": "#07060B", "description": "Primary background - warm black" },
      "voidWarm": { "hex": "#0D0A0F", "description": "Tinted background" },
      "obsidian": { "hex": "#12101A", "description": "Card background" },
      "voidLight": { "hex": "#1a1820", "description": "Light void" },
      "carbon": { "hex": "#252330", "description": "Elevated surface" },
      "surfaceElevated": { "hex": "#1f1d24", "description": "Elevated surface" }
    },

    "colony": {
      "description": "Core Brand Colors",
      "spark": {
        "hex": "#FF6B35",
        "rgb": [255, 107, 53],
        "name": "Ideation",
        "description": "Spark - fire, creativity, new ideas"
      },
      "forge": {
        "hex": "#D4AF37",
        "rgb": [212, 175, 55],
        "name": "Implementation",
        "description": "Forge - gold, craft, building"
      },
      "flow": {
        "hex": "#4ECDC4",
        "rgb": [78, 205, 196],
        "name": "Adaptation",
        "description": "Flow - teal, water, resilience"
      },
      "nexus": {
        "hex": "#9B7EBD",
        "rgb": [155, 126, 189],
        "name": "Integration",
        "description": "Nexus - purple, bridge, connection"
      },
      "beacon": {
        "hex": "#F59E0B",
        "rgb": [245, 158, 11],
        "name": "Planning",
        "description": "Beacon - amber, light, guidance"
      },
      "grove": {
        "hex": "#7EB77F",
        "rgb": [126, 183, 127],
        "name": "Research",
        "description": "Grove - green, nature, growth"
      },
      "crystal": {
        "hex": "#67D4E4",
        "rgb": [103, 212, 228],
        "name": "Verification",
        "description": "Crystal - cyan, clarity, precision"
      }
    },

    "status": {
      "description": "Status Colors",
      "success": { "hex": "#00FF88", "description": "Success green" },
      "error": { "hex": "#FF4444", "description": "Error red" },
      "warning": { "hex": "#FFD700", "description": "Warning yellow" },
      "info": { "hex": "#5AC8FA", "description": "Information blue" }
    },

    "safety": {
      "description": "Control Barrier Function (CBF) Safety Colors",
      "ok": { "hex": "#4ADE80", "description": "h(x) >= 0.5 - Safe" },
      "caution": { "hex": "#FBBF24", "description": "0 <= h(x) < 0.5 - Caution" },
      "violation": { "hex": "#F87171", "description": "h(x) < 0 - Violation" }
    },

    "text": {
      "description": "Text Colors (WCAG AA compliant on void)",
      "primary": { "hex": "#F5F0E8", "opacity": 1.0, "contrast": "15:1" },
      "secondary": { "hex": "#F5F0E8", "opacity": 0.7, "contrast": "7:1" },
      "tertiary": { "hex": "#F5F0E8", "opacity": 0.5, "contrast": "4.6:1" },
      "disabled": { "hex": "#F5F0E8", "opacity": 0.25, "contrast": "Decorative only" }
    },

    "mode": {
      "description": "Mode Colors (Colony-Aligned)",
      "ask": { "ref": "colony.grove", "description": "Research mode" },
      "plan": { "ref": "colony.beacon", "description": "Planning mode" },
      "agent": { "ref": "colony.forge", "description": "Implementation mode" }
    },

    "highContrast": {
      "description": "WCAG AAA High Contrast Overrides",
      "background": "#000000",
      "surface": "#121212",
      "text": "#FFFFFF",
      "textSecondary": "#E0E0E0",
      "accent": "#00FFFF",
      "border": "#FFFFFF",
      "colony": {
        "spark": "#FF7744",
        "forge": "#FFD700",
        "flow": "#00FFFF",
        "nexus": "#CC99FF",
        "beacon": "#FFBB00",
        "grove": "#00FF88",
        "crystal": "#00EEFF"
      }
    }
  },

  "typography": {
    "fontFamily": {
      "ios": { "primary": "SF Pro", "mono": "SF Mono" },
      "android": { "primary": "Roboto", "mono": "Roboto Mono" },
      "desktop": { "primary": "Inter", "mono": "JetBrains Mono" },
      "display": "Newsreader"
    },

    "fontSize": {
      "description": "Font size scale (px)",
      "xs": 11,
      "sm": 13,
      "base": 15,
      "md": 17,
      "lg": 20,
      "xl": 24,
      "2xl": 28,
      "3xl": 34,
      "4xl": 40,
      "display": 48
    },

    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },

    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75
    },

    "letterSpacing": {
      "tight": -0.02,
      "normal": 0,
      "wide": 0.05
    },

    "semantic": {
      "description": "Semantic text styles for platform adaptation",
      "displayLarge": { "size": "4xl", "weight": "bold", "lineHeight": "tight" },
      "displayMedium": { "size": "3xl", "weight": "bold", "lineHeight": "tight" },
      "displaySmall": { "size": "2xl", "weight": "semibold", "lineHeight": "tight" },
      "headlineLarge": { "size": "xl", "weight": "semibold", "lineHeight": "normal" },
      "headlineMedium": { "size": "lg", "weight": "semibold", "lineHeight": "normal" },
      "headlineSmall": { "size": "md", "weight": "semibold", "lineHeight": "normal" },
      "titleLarge": { "size": "lg", "weight": "medium", "lineHeight": "normal" },
      "titleMedium": { "size": "base", "weight": "medium", "lineHeight": "normal" },
      "titleSmall": { "size": "sm", "weight": "medium", "lineHeight": "normal" },
      "bodyLarge": { "size": "md", "weight": "regular", "lineHeight": "relaxed" },
      "bodyMedium": { "size": "base", "weight": "regular", "lineHeight": "relaxed" },
      "bodySmall": { "size": "sm", "weight": "regular", "lineHeight": "relaxed" },
      "labelLarge": { "size": "sm", "weight": "medium", "lineHeight": "normal" },
      "labelMedium": { "size": "xs", "weight": "medium", "lineHeight": "normal" },
      "labelSmall": { "size": "xs", "weight": "regular", "lineHeight": "normal" }
    }
  },

  "spacing": {
    "description": "8pt grid system",
    "unit": 8,
    "xxs": 2,
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "2xl": 40,
    "3xl": 48,
    "4xl": 64,
    "5xl": 80,
    "6xl": 96
  },

  "radius": {
    "description": "Corner radius tokens",
    "none": 0,
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "2xl": 24,
    "3xl": 32,
    "full": 9999
  },

  "motion": {
    "duration": {
      "description": "Standard animation durations (milliseconds)",
      "instant": 89,
      "fast": 144,
      "normal": 233,
      "slow": 377,
      "slower": 610,
      "slowest": 987,
      "glacial": 1597,
      "breathing": 2584
    },

    "easing": {
      "description": "Standard easing curves (cubic-bezier)",
      "snap": {
        "bezier": [0.7, 0, 0.3, 1],
        "description": "Snap - sudden transition"
      },
      "sharp": {
        "bezier": [0.4, 0, 0.2, 1],
        "description": "Sharp - decisive, standard"
      },
      "bounce": {
        "bezier": [0.34, 1.2, 0.64, 1],
        "description": "Bounce - overshoot"
      },
      "elastic": {
        "bezier": [0.68, -0.2, 0.32, 1.2],
        "description": "Elastic - complex oscillation"
      },
      "smooth": {
        "bezier": [0.16, 1, 0.3, 1],
        "description": "Smooth - default expo-out"
      },
      "linear": {
        "bezier": [0, 0, 1, 1],
        "description": "Linear - no easing"
      }
    },

    "spring": {
      "description": "Spring animation parameters",
      "micro": { "damping": 0.8, "stiffness": "high", "response": 0.089 },
      "fast": { "damping": 0.75, "stiffness": "mediumLow", "response": 0.144 },
      "default": { "damping": 0.7, "stiffness": "medium", "response": 0.233 },
      "soft": { "damping": 0.65, "stiffness": "low", "response": 0.377 },
      "bouncy": { "damping": 0.5, "stiffness": "medium", "response": 0.233 }
    }
  },

  "shadows": {
    "description": "Elevation shadow system",
    "none": {
      "offset": [0, 0],
      "blur": 0,
      "spread": 0,
      "opacity": 0
    },
    "sm": {
      "offset": [0, 1],
      "blur": 2,
      "spread": 0,
      "opacity": 0.3
    },
    "md": {
      "offset": [0, 4],
      "blur": 8,
      "spread": 0,
      "opacity": 0.4
    },
    "lg": {
      "offset": [0, 8],
      "blur": 16,
      "spread": 0,
      "opacity": 0.5
    },
    "xl": {
      "offset": [0, 16],
      "blur": 32,
      "spread": 0,
      "opacity": 0.6
    },
    "glow": {
      "offset": [0, 0],
      "blur": 20,
      "spread": 0,
      "opacity": 0.3,
      "color": "crystal"
    },
    "chromatic": {
      "description": "Chromatic aberration shadow",
      "layers": [
        { "offset": [-2, 0], "blur": 8, "color": "spark", "opacity": 0.1 },
        { "offset": [2, 0], "blur": 8, "color": "crystal", "opacity": 0.1 }
      ]
    }
  },

  "elevation": {
    "description": "Elevation levels (maps to shadows)",
    "level0": "none",
    "level1": "sm",
    "level2": "md",
    "level3": "lg",
    "level4": "xl"
  },

  "breakpoints": {
    "description": "Responsive breakpoints (px)",
    "xs": 320,
    "sm": 640,
    "md": 768,
    "lg": 1024,
    "xl": 1280,
    "2xl": 1536
  },

  "effects": {
    "glass": {
      "description": "Apple-style glassmorphism",
      "blur": {
        "thin": 10,
        "regular": 20,
        "thick": 40
      },
      "transparency": {
        "min": 0.70,
        "default": 0.80,
        "max": 0.90
      },
      "border": {
        "width": 1,
        "opacity": 0.10
      }
    },

    "spectral": {
      "description": "Spectral shimmer effect (7 color phases)",
      "phaseCount": 7,
      "shimmer": {
        "duration": 8000,
        "opacity": { "idle": 0, "hover": 0.3, "active": 0.5 }
      },
      "border": {
        "width": 2,
        "duration": 6000
      }
    },

    "caustics": {
      "description": "Animated rainbow light patterns",
      "layers": 3,
      "durations": [25000, 30000, 35000],
      "opacity": { "min": 0.4, "max": 0.7 }
    }
  },

  "zIndex": {
    "description": "Z-index layers for stacking context",
    "base": 0,
    "dropdown": 100,
    "sticky": 200,
    "modalBackdrop": 299,
    "modal": 300,
    "popover": 400,
    "tooltip": 500,
    "toast": 600,
    "cursor": 1000
  },

  "accessibility": {
    "touchTarget": {
      "minimum": 44,
      "minimumAndroid": 48,
      "recommended": 56
    },
    "contrast": {
      "normalAA": 4.5,
      "largeAA": 3.0,
      "normalAAA": 7.0,
      "largeAAA": 4.5
    },
    "focus": {
      "outlineWidth": 2,
      "outlineOffset": 2,
      "color": "crystal"
    }
  },

  "platform": {
    "description": "Platform-specific overrides",
    "ios": {
      "navBarHeight": 44,
      "largeNavBarHeight": 96,
      "tabBarHeight": 49,
      "homeIndicatorPadding": 34
    },
    "android": {
      "statusBarHeight": 24,
      "appBarHeight": 56,
      "bottomNavHeight": 56
    },
    "visionOS": {
      "windowDefault": [400, 300],
      "windowMedium": [500, 400],
      "windowLarge": [700, 500],
      "spatialNear": 0.5,
      "spatialArm": 0.75,
      "spatialComfort": 1.0,
      "spatialRoom": 2.0
    },
    "watchOS": {
      "contentMargins": 8,
      "titleHeight": 38,
      "listRowHeight": 44
    }
  }
}
