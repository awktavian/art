{
  "name": "@kagami/qa-pipeline",
  "version": "0.1.0",
  "description": "Gemini-powered video analysis pipeline for automated QA testing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qa-analyze": "./dist/bin/qa-analyze.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "cli": "tsx bin/qa-analyze.ts",
    "gemini:analyze": "node dist/bin/qa-analyze.js gemini",
    "gemini:analyze:dev": "tsx bin/qa-analyze.ts gemini",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"bin/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@google-cloud/storage": "^7.7.0",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^3.5.3",
    "commander": "^12.1.0",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "p-queue": "^8.0.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "sharp": "^0.33.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.6.1",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "qa",
    "testing",
    "video-analysis",
    "gemini",
    "ai",
    "automation"
  ],
  "author": "Kagami",
  "license": "MIT"
}
