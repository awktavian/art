# Kagami QA Pipeline Configuration
# Copy this file to .env and fill in your values

# Required: Gemini API Key
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: Gemini model to use
# GEMINI_MODEL=gemini-2.0-flash-exp

# Optional: Rate limiting
# GEMINI_RPM=10
# GEMINI_RPD=1500

# Server configuration
# QA_PIPELINE_PORT=3847
# QA_PIPELINE_HOST=localhost

# Storage configuration
# STORAGE_TYPE=local
# STORAGE_LOCAL_PATH=./data

# For Google Cloud Storage:
# STORAGE_TYPE=gcs
# GCS_BUCKET=your-bucket-name
# GCS_KEY_FILE=/path/to/service-account.json

# Database
# DATABASE_PATH=./data/qa-pipeline.db

# Processing
# MAX_CONCURRENT_JOBS=2
# FRAME_INTERVAL=1
# MAX_FRAMES=100
# TEMP_DIR=./data/temp
# MAX_VIDEO_SIZE_MB=500

# Pipeline
# WATCH_DIRS=./test-videos,./recordings
# AUTO_ANALYZE=false
# RETAIN_DAYS=30

# Logging
# LOG_LEVEL=debug
# NODE_ENV=development
