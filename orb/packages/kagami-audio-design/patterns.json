      "audio": {
        "sequence": [
          { "freq": 349, "duration_ms": 100, "note": "F4", "role": "falling_brightness" }
        ],
        "envelope": "soft",
        "total_duration_ms": 100
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.soft(intensity:0.5)",
        "watchos": ["WKHapticType.directionDown", "WKHapticType.click"],
        "android": "VibrationEffect.EFFECT_TICK"
      },
      "visionos_spatial": {
        "zone": "social",
        "distance_m": 2.0,
        "position": "at_light",
        "reason": "Audio positioned at actual light location"
      }
    },

    "light_dim": {
      "semantic": "Lights dimming",
      "musical_hint": "Middle C = neutral intermediate state",
      "audio": {
        "sequence": [
          { "freq": 523, "duration_ms": 50, "note": "C5" }
        ],
        "envelope": "soft",
        "total_duration_ms": 50
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.soft(intensity:0.4)",
        "watchos": "WKHapticType.click",
        "android": "VibrationEffect.EFFECT_TICK"
      }
    },

