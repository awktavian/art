        "reason": "Scene affects the whole room - immersive audio"
      }
    },

    "tv_raise": {
      "semantic": "TV mount rising",
      "musical_hint": "Ascending pattern = rising mount",
      "audio": {
        "sequence": [
          { "freq": 392, "duration_ms": 150, "note": "G4" },
          { "freq": 523, "duration_ms": 150, "note": "C5" }
        ],
        "envelope": "soft",
        "total_duration_ms": 300
      },
      "haptic": {
