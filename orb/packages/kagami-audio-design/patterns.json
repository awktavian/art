{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "2.0.0",
  "description": "Kagami Unified Audio Design System - Canonical Pattern Definitions",
  "musical_theory": {
    "_comment": "C-E-G = C major chord = HAPPY! Descending intervals = SAD. High frequencies = URGENT.",
    "c_major_chord": "523-659-784 Hz (C5-E5-G5) = Success, triumph, joy",
    "descending_interval": "440-349 Hz (A4-F4) = Error, disappointment",
    "high_frequency_alert": "880-1047 Hz (A5-C6) = Warning, emergency"
  },

  "fibonacci_timing": {
    "_comment": "Fibonacci durations feel organic because φ ≈ 1.618 is found throughout nature",
    "values_ms": [34, 55, 89, 144, 233, 377, 610, 987, 1597],
    "mapping": {
      "34": "instantaneous (click)",
      "55": "quick tap",
      "89": "micro-interaction (selection, navigation)",
      "144": "button response (confirmation)",
      "233": "short feedback (notification)",
      "377": "standard feedback (success, error)",
      "610": "rich feedback (scene changes)",
      "987": "ambient transitions (wake/sleep)"
    }
  },

  "patterns": {
    "success": {
      "semantic": "Action completed positively",
      "musical_hint": "C major arpeggio ascending = 'We did it!'",
      "audio": {
        "sequence": [
          { "freq": 523, "duration_ms": 100, "note": "C5", "role": "root" },
          { "freq": 659, "duration_ms": 100, "note": "E5", "role": "major_third" },
          { "freq": 784, "duration_ms": 150, "note": "G5", "role": "perfect_fifth" }
        ],
        "envelope": "soft",
        "total_duration_ms": 350
      },
      "haptic": {
        "ios": "UINotificationFeedbackGenerator.success",
        "watchos": "WKHapticType.success",
        "android": "VibrationEffect.createComposition().addPrimitive(PRIMITIVE_CLICK).addPrimitive(PRIMITIVE_CLICK)"
      },
      "visionos_spatial": {
        "zone": "intimate",
        "distance_m": 0.3,
        "position": "center",
        "reason": "Personal achievement, close and centered"
      }
    },

    "error": {
      "semantic": "Action failed",
      "musical_hint": "Descending interval = disappointment",
      "audio": {
        "sequence": [
          { "freq": 440, "duration_ms": 150, "note": "A4", "role": "start_confident" },
          { "freq": 349, "duration_ms": 200, "note": "F4", "role": "drop_down_sad" }
        ],
        "envelope": "harsh",
        "total_duration_ms": 350
      },
      "haptic": {
        "ios": "UINotificationFeedbackGenerator.error",
        "watchos": "WKHapticType.failure",
        "android": "VibrationEffect.EFFECT_DOUBLE_CLICK"
      },
      "visionos_spatial": {
        "zone": "personal",
        "distance_m": 1.0,
        "position": "center",
        "reason": "Needs attention but not alarming"
      }
    },

    "warning": {
      "semantic": "Attention needed",
      "musical_hint": "Single sustained high note = attention",
      "audio": {
        "sequence": [
          { "freq": 880, "duration_ms": 200, "note": "A5", "role": "attention_grabbing" }
        ],
        "envelope": "soft",
        "total_duration_ms": 200
      },
      "haptic": {
        "ios": "UINotificationFeedbackGenerator.warning",
        "watchos": "WKHapticType.notification",
        "android": "VibrationEffect.EFFECT_HEAVY_CLICK"
      },
      "visionos_spatial": {
        "zone": "personal",
        "distance_m": 0.8,
        "position": "center",
        "reason": "Attention needed but not urgent"
      }
    },

    "emergency": {
      "semantic": "CRITICAL: Life/property threat - fire, intrusion, medical",
      "musical_hint": "Alternating high frequencies = DANGER! Cannot be ignored!",
      "priority": "P0_CRITICAL",
      "audio": {
        "sequence": [
          { "freq": 1047, "duration_ms": 150, "note": "C6", "role": "piercing_high" },
          { "rest": 50 },
          { "freq": 880, "duration_ms": 150, "note": "A5", "role": "alert" },
          { "rest": 50 },
          { "freq": 1047, "duration_ms": 150, "note": "C6", "role": "piercing_high" },
          { "rest": 50 },
          { "freq": 880, "duration_ms": 150, "note": "A5", "role": "alert" }
        ],
        "envelope": "harsh",
        "base_duration_ms": 750,
        "repeat": 5,
        "repeat_gap_ms": 300,
        "total_duration_ms": 4950,
        "continues_until_acknowledged": true,
        "_duration_calculation": "5 * 750ms + 4 * 300ms = 4950ms minimum, repeats until user acknowledges",
        "overrides_user_volume": true
      },
      "haptic": {
        "ios": {
          "sequence": ["UINotificationFeedbackGenerator.error"],
          "continuous": true,
          "until_acknowledged": true,
          "intensity": 1.0
        },
        "watchos": {
          "sequence": ["WKHapticType.failure"],
          "continuous": true
        },
        "android": {
          "pattern": [0, 200, 100, 200, 100, 200, 100, 200],
          "amplitudes": [255, 0, 255, 0, 255, 0, 255],
          "repeat": 0,
          "_comment": "repeat: 0 means indefinite repeat"
        }
      },
      "visual": {
        "screen_flash": {
          "color": "#FF0000",
          "frequency_hz": 2,
          "duration_ms": "until_acknowledged"
        },
        "persistent_banner": {
          "background_color": "#FF0000",
          "text_color": "#FFFFFF",
          "contrast_ratio": 21,
          "message_key": "emergency.alert.{type}"
        },
        "led_indicator": {
          "pattern": "rapid_blink",
          "color": "#FF0000"
        }
      },
      "visionos_spatial": {
        "zone": "intimate",
        "distance_m": 0.2,
        "position": "surround",
        "surround_positions": [
          { "x": 0, "y": 0, "z": -0.2, "label": "front" },
          { "x": 0, "y": 0, "z": 0.2, "label": "back" },
          { "x": -0.2, "y": 0, "z": 0, "label": "left" },
          { "x": 0.2, "y": 0, "z": 0, "label": "right" },
          { "x": 0, "y": 0.2, "z": 0, "label": "above" }
        ],
        "reason": "MUST be unavoidable - audio from all directions"
      }
    },

    "safety_alert": {
      "semantic": "h(x) < 0 warning - Safety constraint violation",
      "musical_hint": "Repeated high tones = urgent warning",
      "priority": "P0_HIGH",
      "escalation": {
        "escalates_to": "emergency",
        "escalation_timeout_ms": 30000,
        "condition": "unacknowledged after 30 seconds"
      },
      "audio": {
        "sequence": [
          { "freq": 880, "duration_ms": 200, "note": "A5", "role": "warning" },
          { "rest": 100 },
          { "freq": 880, "duration_ms": 200, "note": "A5", "role": "warning_repeat" }
        ],
        "envelope": "harsh",
        "base_duration_ms": 500,
        "repeat": 3,
        "total_duration_ms": 1500,
        "_duration_calculation": "3 * 500ms = 1500ms total"
      },
      "haptic": {
        "ios": ["UIImpactFeedbackGenerator.heavy", "delay:150", "UIImpactFeedbackGenerator.heavy", "delay:150", "UIImpactFeedbackGenerator.heavy", "UINotificationFeedbackGenerator.error"],
        "watchos": ["WKHapticType.notification", "WKHapticType.failure", "WKHapticType.failure", "WKHapticType.failure"],
        "android": { "pattern": [0, 200, 100, 200, 100, 200], "amplitudes": [255, 0, 255, 0, 255] }
      },
      "visual": {
        "screen_border": {
          "color": "#FFA500",
          "width_px": 8,
          "pulse": true
        },
        "persistent_banner": {
          "background_color": "#FFA500",
          "text_color": "#000000",
          "contrast_ratio": 10,
          "message_key": "safety.alert.{constraint}"
        }
      },
      "visionos_spatial": {
        "zone": "intimate",
        "distance_m": 0.3,
        "position": "front_and_above",
        "positions": [
          { "x": 0, "y": 0, "z": -0.3, "label": "front" },
          { "x": 0, "y": 0.15, "z": -0.3, "label": "above" }
        ],
        "reason": "Safety violation requires immediate attention from multiple directions"
      }
    },

    "notification": {
      "semantic": "New information",
      "musical_hint": "Rising fifth = something new arriving",
      "audio": {
        "sequence": [
          { "freq": 784, "duration_ms": 100, "note": "G5" },
          { "freq": 1047, "duration_ms": 150, "note": "C6" }
        ],
        "envelope": "soft",
        "total_duration_ms": 250
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.light",
        "watchos": "WKHapticType.click",
        "android": "VibrationEffect.EFFECT_TICK"
      },
      "visionos_spatial": {
        "zone": "personal",
        "distance_m": 1.0,
        "position": { "x": 0.5, "y": 0.2, "z": -1.0 },
        "reason": "Natural notification position (slightly right and up)"
      }
    },

    "selection": {
      "semantic": "Item selected",
      "musical_hint": "Brief high tick = crisp acknowledgment",
      "audio": {
        "sequence": [
          { "freq": 880, "duration_ms": 50, "note": "A5", "role": "brief_tick" }
        ],
        "envelope": "sharp",
        "total_duration_ms": 50
      },
      "haptic": {
        "ios": "UISelectionFeedbackGenerator.selectionChanged",
        "watchos": "WKHapticType.click",
        "android": "VibrationEffect.EFFECT_TICK"
      },
      "visionos_spatial": {
        "zone": "intimate",
        "distance_m": 0.3,
        "position": "at_selection",
        "reason": "Audio appears at selected element location"
      }
    },

    "navigation_up": {
      "semantic": "Moving up in UI",
      "musical_hint": "Higher pitch = upward motion",
      "audio": {
        "sequence": [
          { "freq": 659, "duration_ms": 30, "note": "E5" }
        ],
        "envelope": "sharp",
        "total_duration_ms": 30
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.light",
        "watchos": "WKHapticType.directionUp",
        "android": "VibrationEffect.EFFECT_TICK"
      },
      "visionos_spatial": {
        "zone": "intimate",
        "distance_m": 0.3,
        "position": { "x": 0, "y": 0.1, "z": -0.3 },
        "reason": "Slightly above center to reinforce 'up' direction for blind users"
      }
    },

    "navigation_down": {
      "semantic": "Moving down in UI",
      "musical_hint": "Lower pitch = downward motion",
      "audio": {
        "sequence": [
          { "freq": 440, "duration_ms": 30, "note": "A4" }
        ],
        "envelope": "sharp",
        "total_duration_ms": 30
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.light",
        "watchos": "WKHapticType.directionDown",
        "android": "VibrationEffect.EFFECT_TICK"
      },
      "visionos_spatial": {
        "zone": "intimate",
        "distance_m": 0.3,
        "position": { "x": 0, "y": -0.1, "z": -0.3 },
        "reason": "Slightly below center to reinforce 'down' direction for blind users"
      }
    },

    "confirmation": {
      "semantic": "Action confirmed",
      "musical_hint": "Double tap with rising end = yes, confirmed",
      "audio": {
        "sequence": [
          { "freq": 659, "duration_ms": 50, "note": "E5" },
          { "rest": 30 },
          { "freq": 784, "duration_ms": 80, "note": "G5", "role": "rising_confirmation" }
        ],
        "envelope": "soft",
        "total_duration_ms": 160
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.medium",
        "watchos": "WKHapticType.click",
        "android": "VibrationEffect.EFFECT_CLICK"
      },
      "visionos_spatial": {
        "zone": "intimate",
        "distance_m": 0.3,
        "position": { "x": 0, "y": 0, "z": -0.3 },
        "reason": "Confirmation centered in front of user"
      }
    },

    "thermostat_up": {
      "semantic": "Temperature increasing",
      "musical_hint": "Ascending warmth = temperature rising",
      "audio": {
        "sequence": [
          { "freq": 440, "duration_ms": 100, "note": "A4", "role": "warm_base" },
          { "freq": 523, "duration_ms": 100, "note": "C5", "role": "rising" },
          { "freq": 659, "duration_ms": 100, "note": "E5", "role": "warm_peak" }
        ],
        "envelope": "soft",
        "total_duration_ms": 300
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.light(intensity:0.6)",
        "watchos": "WKHapticType.directionUp",
        "android": "VibrationEffect.EFFECT_CLICK"
      },
      "visionos_spatial": {
        "zone": "social",
        "distance_m": 2.0,
        "position": "at_thermostat",
        "reason": "Position at thermostat physical location"
      }
    },

    "thermostat_down": {
      "semantic": "Temperature decreasing",
      "musical_hint": "Descending cool = temperature falling",
      "audio": {
        "sequence": [
          { "freq": 659, "duration_ms": 100, "note": "E5", "role": "start_high" },
          { "freq": 523, "duration_ms": 100, "note": "C5", "role": "falling" },
          { "freq": 440, "duration_ms": 100, "note": "A4", "role": "cool_base" }
        ],
        "envelope": "soft",
        "total_duration_ms": 300
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.soft(intensity:0.6)",
        "watchos": "WKHapticType.directionDown",
        "android": "VibrationEffect.EFFECT_TICK"
      },
      "visionos_spatial": {
        "zone": "social",
        "distance_m": 2.0,
        "position": "at_thermostat",
        "reason": "Position at thermostat physical location"
      }
    },

    "light_on": {
      "semantic": "Lights turning on",
      "musical_hint": "Rising brightness = F5 (bright frequency)",
      "audio": {
        "sequence": [
          { "freq": 698, "duration_ms": 100, "note": "F5", "role": "rising_brightness" }
        ],
        "envelope": "soft",
        "total_duration_ms": 100
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.light(intensity:0.7)",
        "watchos": ["WKHapticType.directionUp", "WKHapticType.success"],
        "android": "VibrationEffect.EFFECT_CLICK"
      },
      "visionos_spatial": {
        "zone": "social",
        "distance_m": 2.0,
