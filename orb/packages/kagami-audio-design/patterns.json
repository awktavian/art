        "sequence": [
          { "freq": 262, "duration_ms": 50, "note": "C4", "role": "low_thud" }
        ],
        "envelope": "sharp",
        "total_duration_ms": 50
      },
      "haptic": {
        "ios": "UIImpactFeedbackGenerator.rigid(intensity:0.3)",
