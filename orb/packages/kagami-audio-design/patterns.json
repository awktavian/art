          { "freq": 523, "duration_ms": 100, "note": "C5" }
        ],
        "envelope": "soft",
        "total_duration_ms": 200
      },
      "haptic": {
        "ios": ["UIImpactFeedbackGenerator.light", "delay:100", "UIImpactFeedbackGenerator.light"],
        "watchos": ["WKHapticType.directionUp", "WKHapticType.directionUp", "WKHapticType.success"],
        "android": { "pattern": [0, 50, 50, 50] }
      },
      "visionos_spatial": {
        "zone": "social",
        "distance_m": 2.5,
