          { "freq": 659, "duration_ms": 50, "note": "E5", "role": "initial_engagement" },
          { "rest": 30 },
          { "freq": 880, "duration_ms": 100, "note": "A5", "role": "firm_confirmation" }
        ],
        "envelope": "sharp",
        "total_duration_ms": 180
      },
      "haptic": {
        "ios": ["UIImpactFeedbackGenerator.rigid", "delay:100", "UIImpactFeedbackGenerator.heavy"],
        "watchos": ["WKHapticType.click", "WKHapticType.retry"],
