        "reason": "Position at window/shade location"
      }
    },

    "shades_close": {
      "semantic": "Shades closing",
      "musical_hint": "Falling sweep = closing off the outside",
      "audio": {
        "sequence": [
          { "freq": 523, "duration_ms": 100, "note": "C5" },
          { "freq": 262, "duration_ms": 100, "note": "C4" }
        ],
        "envelope": "soft",
        "total_duration_ms": 200
      },
      "haptic": {
        "ios": ["UIImpactFeedbackGenerator.soft", "delay:100", "UIImpactFeedbackGenerator.soft"],
        "watchos": ["WKHapticType.directionDown", "WKHapticType.directionDown", "WKHapticType.click"],
        "android": { "pattern": [0, 50, 50, 50] }
      },
      "visionos_spatial": {
        "zone": "social",
        "distance_m": 2.5,
        "position": "at_window",
        "reason": "Position at window/shade location"
      }
    },

    "fireplace_on": {
      "semantic": "Fireplace igniting",
      "musical_hint": "Warm rising pattern = cozy warmth building",
      "audio": {
        "sequence": [
          { "freq": 330, "duration_ms": 150, "note": "E4", "role": "warm_ember" },
          { "freq": 440, "duration_ms": 150, "note": "A4", "role": "flame_growing" },
          { "freq": 523, "duration_ms": 200, "note": "C5", "role": "full_fire" }
        ],
        "envelope": "soft",
        "total_duration_ms": 500
      },
      "haptic": {
        "ios": ["UIImpactFeedbackGenerator.light", "delay:150", "UIImpactFeedbackGenerator.light", "delay:150", "UIImpactFeedbackGenerator.light", "UINotificationFeedbackGenerator.success"],
        "watchos": ["WKHapticType.directionUp", "WKHapticType.directionUp", "WKHapticType.directionUp", "WKHapticType.success"],
        "android": { "pattern": [0, 75, 75, 75, 75, 100] }
      },
      "visionos_spatial": {
        "zone": "social",
        "distance_m": 3.0,
        "position": "at_fireplace",
        "reason": "Position at fireplace physical location"
      }
    },

    "fireplace_off": {
      "semantic": "Fireplace extinguishing",
      "musical_hint": "Cool falling pattern = warmth fading",
      "audio": {
        "sequence": [
          { "freq": 523, "duration_ms": 150, "note": "C5", "role": "full_fire" },
          { "freq": 440, "duration_ms": 150, "note": "A4", "role": "flame_dimming" },
          { "freq": 262, "duration_ms": 200, "note": "C4", "role": "embers_cooling" }
        ],
        "envelope": "soft",
        "total_duration_ms": 500
      },
      "haptic": {
        "ios": ["UIImpactFeedbackGenerator.soft", "delay:150", "UIImpactFeedbackGenerator.soft", "delay:150", "UIImpactFeedbackGenerator.soft"],
        "watchos": ["WKHapticType.directionDown", "WKHapticType.directionDown", "WKHapticType.directionDown", "WKHapticType.click"],
        "android": { "pattern": [0, 75, 75, 75, 75, 100] }
      },
      "visionos_spatial": {
        "zone": "social",
        "distance_m": 3.0,
        "position": "at_fireplace",
        "reason": "Position at fireplace physical location"
      }
    },

