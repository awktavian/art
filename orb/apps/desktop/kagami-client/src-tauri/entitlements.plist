<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    鏡 Kagami Desktop Client — macOS Entitlements

    Enables full system integration capabilities for smart home control:
    - Network access for Kagami API communication
    - Local network server for mDNS discovery (kagami.local)
    - Microphone access for voice commands
    - Calendar access for context-aware suggestions
    - Location for presence detection
    - Accessibility for global hotkeys

    Note: App Sandbox is DISABLED to allow system integration.
    The app must be manually approved in System Preferences.

    h(x) >= 0. Always.
-->
<plist version="1.0">
<dict>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SANDBOX DISABLED                                                     -->
    <!-- Required for full system access and smart home control              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- HARDENED RUNTIME                                                     -->
    <!-- Security settings required for notarization                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <false/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- NETWORK ACCESS                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Outgoing network connections (API, WebSocket) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Local network server for mDNS discovery (kagami.local) -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- DEVICE ACCESS                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Microphone access for voice commands -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PERSONAL INFORMATION ACCESS                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Calendar access for context-aware suggestions -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>

    <!-- Location for presence detection -->
    <key>com.apple.security.personal-information.location</key>
    <true/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- AUTOMATION                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Accessibility for global hotkeys (Option+K, etc.) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FILE ACCESS                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- User-selected file access for HAL integration -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- KEYCHAIN ACCESS                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Keychain access for secure credential storage -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.kagami.client</string>
    </array>
</dict>
</plist>
