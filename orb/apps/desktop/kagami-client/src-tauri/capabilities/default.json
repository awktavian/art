{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capability for Kagami client with full desktop control",
  "windows": ["quick-entry", "room-dashboard", "voice-monitor"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "notification:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-read-dir",
    "process:allow-exit",
    "process:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:allow-write-image"
  ]
}
