# Docker ignore for visual tests
# Keep the image lean for faster builds

# Node modules (reinstalled in container)
node_modules/

# Build artifacts
dist/
*.dmg
*.exe
*.msi
*.AppImage

# Tauri build artifacts
src-tauri/target/

# Test output (we mount snapshots separately)
test-results/

# IDE files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation (not needed for tests)
*.md
!tests/visual/*.md

# Logs
*.log
npm-debug.log*
