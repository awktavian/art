<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Optional permissions -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".KagamiApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kagami"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Kagami">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget Configuration Activity -->
        <activity
            android:name=".widgets.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.Kagami">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Safety Widget Receiver (2x1 - h(x) safety score display) -->
        <receiver
            android:name=".widgets.SafetyWidgetReceiver"
            android:exported="true"
            android:label="@string/safety_widget_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kagami.android.widgets.REFRESH_SAFETY" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/safety_widget_info" />
        </receiver>

        <!-- Quick Actions Widget Receiver (4x2 - scene buttons) -->
        <receiver
            android:name=".widgets.QuickActionsWidgetReceiver"
            android:exported="true"
            android:label="@string/quick_actions_widget_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kagami.android.widgets.REFRESH_QUICK_ACTIONS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_actions_widget_info" />
        </receiver>

        <!-- Room Control Widget Receiver (4x4 - per-room controls) -->
        <receiver
            android:name=".widgets.RoomControlWidgetReceiver"
            android:exported="true"
            android:label="@string/room_control_widget_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kagami.android.widgets.REFRESH_ROOM_CONTROL" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/room_control_widget_info" />
        </receiver>

        <!-- Dashboard Widget Receiver (4x4 - full home dashboard) -->
        <receiver
            android:name=".widgets.DashboardWidgetReceiver"
            android:exported="true"
            android:label="@string/dashboard_widget_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kagami.android.widgets.REFRESH_DASHBOARD" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dashboard_widget_info" />
        </receiver>

        <!-- Quick Settings Tile Services -->
        <service
            android:name=".tiles.LightsTileService"
            android:exported="true"
            android:icon="@drawable/ic_lights"
            android:label="Kagami Lights"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="false" />
        </service>

        <service
            android:name=".tiles.MovieModeTileService"
            android:exported="true"
            android:icon="@drawable/ic_movie"
            android:label="Movie Mode"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".tiles.GoodnightTileService"
            android:exported="true"
            android:icon="@drawable/ic_night"
            android:label="Goodnight"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".tiles.FireplaceTileService"
            android:exported="true"
            android:icon="@drawable/ic_fireplace"
            android:label="Fireplace"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".tiles.HeroActionTileService"
            android:exported="true"
            android:icon="@drawable/ic_kagami"
            android:label="Kagami Action"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="false" />
        </service>

        <service
            android:name=".tiles.ShadesTileService"
            android:exported="true"
            android:icon="@drawable/ic_shades"
            android:label="Shades"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- WorkManager Initializer (for HiltWorker) -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
