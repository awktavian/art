<?xml version="1.0" encoding="utf-8"?>
<!--
  Kagami Quick Actions Widget Configuration

  Colony: Nexus (e4) - Integration
  Medium (4x2) widget with scene buttons

  h(x) >= 0. Always.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:minResizeWidth="180dp"
    android:minResizeHeight="80dp"
    android:maxResizeWidth="400dp"
    android:maxResizeHeight="180dp"
    android:resizeMode="horizontal|vertical"
    android:updatePeriodMillis="900000"
    android:previewImage="@drawable/widget_quick_actions_preview_image"
    android:previewLayout="@layout/widget_quick_actions_preview"
    android:description="@string/quick_actions_widget_description"
    android:widgetCategory="home_screen"
    android:widgetFeatures="reconfigurable"
    android:initialLayout="@layout/glance_default_loading_layout" />
