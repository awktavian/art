<?xml version="1.0" encoding="utf-8"?>
<!--
  Kagami Dashboard Widget Configuration

  Colony: Nexus (e4) - Integration
  Large (4x4) full home dashboard widget

  h(x) >= 0. Always.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="250dp"
    android:targetCellWidth="4"
    android:targetCellHeight="4"
    android:minResizeWidth="180dp"
    android:minResizeHeight="180dp"
    android:maxResizeWidth="400dp"
    android:maxResizeHeight="400dp"
    android:resizeMode="horizontal|vertical"
    android:updatePeriodMillis="600000"
    android:previewImage="@drawable/widget_room_control_preview_image"
    android:description="@string/dashboard_widget_description"
    android:widgetCategory="home_screen"
    android:widgetFeatures="reconfigurable"
    android:initialLayout="@layout/glance_default_loading_layout" />
