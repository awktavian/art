<?xml version="1.0" encoding="utf-8"?>
<!--
  Room Control Widget Preview Image (Vector Drawable)
  For Android 12+ widget picker

  Colony: Nexus (e4) - Integration
  h(x) >= 0. Always.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background with rounded corners -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1E" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Grid layout suggestion -->
    <item
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#2A2A2E" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Accent bar at top -->
    <item
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <size android:height="4dp" />
            <solid android:color="#67D4E4" />
            <corners
                android:topLeftRadius="16dp"
                android:topRightRadius="16dp" />
        </shape>
    </item>

</layer-list>
