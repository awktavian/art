<?xml version="1.0" encoding="utf-8"?>
<!--
  Kagami Google Assistant App Actions

  Colony: Beacon (e5) - Planning
  Voice commands: "Hey Google, turn on movie mode in Kagami"

  h(x) >= 0. Always.
-->
<actions>

    <!-- Open App Feature - Activate scenes by name -->
    <action intentName="actions.intent.OPEN_APP_FEATURE">
        <fulfillment urlTemplate="kagami://scene/{feature}">
            <parameter-mapping
                urlParameter="feature"
                intentParameter="feature"
                required="true" />
        </fulfillment>

        <!-- Inline inventory for scene names -->
        <parameter name="feature">
            <entity-set-reference
                urlFilter="^movie.*mode$"
                entitySetId="MovieModeScenes" />
            <entity-set-reference
                urlFilter="^goodnight$"
                entitySetId="GoodnightScenes" />
            <entity-set-reference
                urlFilter="^welcome.*home$"
                entitySetId="WelcomeHomeScenes" />
            <entity-set-reference
                urlFilter="^focus.*mode$"
                entitySetId="FocusScenes" />
            <entity-set-reference
                urlFilter="^relax$"
                entitySetId="RelaxScenes" />
            <entity-set-reference
                urlFilter="^away.*mode$"
                entitySetId="AwayScenes" />
        </parameter>
    </action>

    <!-- Entity Sets for Scene Names -->
    <entity-set entitySetId="MovieModeScenes">
        <entity
            name="movie mode"
            alternateName="@array/movie_mode_synonyms"
            identifier="movie_mode" />
    </entity-set>

    <entity-set entitySetId="GoodnightScenes">
        <entity
            name="goodnight"
            alternateName="@array/goodnight_synonyms"
            identifier="goodnight" />
    </entity-set>

    <entity-set entitySetId="WelcomeHomeScenes">
        <entity
            name="welcome home"
            alternateName="@array/welcome_home_synonyms"
            identifier="welcome_home" />
    </entity-set>

    <entity-set entitySetId="FocusScenes">
        <entity
            name="focus mode"
            alternateName="@array/focus_synonyms"
            identifier="focus" />
    </entity-set>

    <entity-set entitySetId="RelaxScenes">
        <entity
            name="relax"
            alternateName="@array/relax_synonyms"
            identifier="relax" />
    </entity-set>

    <entity-set entitySetId="AwayScenes">
        <entity
            name="away mode"
            alternateName="@array/away_synonyms"
            identifier="away" />
    </entity-set>

    <!-- Control Smart Home Device - Turn lights on/off -->
    <action intentName="actions.intent.TOGGLE_ON_OFF">
        <fulfillment urlTemplate="kagami://lights/{state}">
            <parameter-mapping
                urlParameter="state"
                intentParameter="action.toggle.state"
                required="true" />
        </fulfillment>
    </action>

</actions>
