<?xml version="1.0" encoding="utf-8"?>
<!--
  Kagami Theme - Material 3 with Dynamic Color Support

  Unified design system matching iOS/Swift, Desktop/Tauri, and Web.

  Features:
  - Dynamic Color (Material You) on Android 12+
  - High Contrast mode support
  - Edge-to-edge rendering
  - Proper surface container hierarchy

  Safety First.
-->
<resources>
    <!-- ============================================================= -->
    <!-- Base Dark Theme (Default) -->
    <!-- ============================================================= -->
    <style name="Theme.Kagami" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (Crystal) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Secondary brand color (Nexus) -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- Tertiary brand color (Forge) -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>

        <!-- Background and surface colors (Void palette) -->
        <item name="android:colorBackground">@color/void_color</item>
        <item name="colorSurface">@color/void_light</item>
        <item name="colorSurfaceVariant">@color/void_light</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Surface container hierarchy (M3) -->
        <item name="colorSurfaceContainerLowest">@color/surface_container_lowest</item>
        <item name="colorSurfaceContainerLow">@color/surface_container_low</item>
        <item name="colorSurfaceContainer">@color/surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/surface_container_high</item>
        <item name="colorSurfaceContainerHighest">@color/surface_container_highest</item>

        <!-- Error colors -->
        <item name="colorError">@color/safety_violation</item>
        <item name="colorOnError">@color/text_primary</item>

        <!-- Outline colors -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <!-- Edge-to-edge configuration -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Enable edge-to-edge drawing -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:fitsSystemWindows">false</item>
    </style>

    <!-- ============================================================= -->
    <!-- High Contrast Theme (Accessibility) -->
    <!-- WCAG AAA compliant colors for maximum visibility -->
    <!-- ============================================================= -->
    <style name="Theme.Kagami.HighContrast" parent="Theme.Kagami">
        <!-- High contrast primary -->
        <item name="colorPrimary">@color/hc_accent</item>
        <item name="colorOnPrimary">@color/hc_background</item>

        <!-- High contrast secondary -->
        <item name="colorSecondary">@color/hc_accent</item>
        <item name="colorOnSecondary">@color/hc_background</item>

        <!-- High contrast surfaces -->
        <item name="android:colorBackground">@color/hc_background</item>
        <item name="colorSurface">@color/hc_surface</item>
        <item name="colorSurfaceVariant">@color/hc_surface</item>
        <item name="colorOnSurface">@color/hc_text</item>
        <item name="colorOnSurfaceVariant">@color/hc_text</item>

        <!-- High contrast outline -->
        <item name="colorOutline">@color/hc_border</item>

        <!-- High contrast error -->
        <item name="colorError">@color/hc_error</item>
    </style>

    <!-- ============================================================= -->
    <!-- Widget Theme (Glanceable) -->
    <!-- Optimized for home screen widgets -->
    <!-- ============================================================= -->
    <style name="Theme.Kagami.Widget" parent="Theme.Kagami">
        <item name="android:colorBackground">@color/obsidian</item>
        <item name="colorSurface">@color/carbon</item>
    </style>
</resources>
