<?xml version="1.0" encoding="utf-8"?>
<!--
  Quick Actions Widget Preview Image (Vector Drawable)
  For Android 12+ widget picker

  Colony: Nexus (e4) - Integration
  h(x) >= 0. Always.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background with rounded corners -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1E" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Grid pattern suggestion for buttons -->
    <item
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#2A2A2E"
                android:dashWidth="4dp"
                android:dashGap="4dp" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</layer-list>
