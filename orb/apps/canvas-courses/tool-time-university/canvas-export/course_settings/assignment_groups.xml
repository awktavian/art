       TOOL TIME CHALLENGES (32%)
       Major creative projects analyzing episodes and demonstrating mastery
       ═══════════════════════════════════════════════════════════════════════════ -->
  <assignmentGroup identifier="ag_tool_time_challenges">
    <title>Tool Time Challenges</title>
    <position>1</position>
    <group_weight>32</group_weight>
    <rules>
      <drop_lowest>0</drop_lowest>
      <drop_highest>0</drop_highest>
      <never_drop/>
    </rules>

    <!-- Module 1: Origin Story Analysis -->
    <assignment identifier="ttc_mod01">
      <title>Tool Time Challenge 01: Origin Story Analysis</title>
      <points_possible>2500</points_possible>
      <grading_type>points</grading_type>
      <submission_types>online_text_entry,online_upload</submission_types>
      <description><![CDATA[
        <p>Watch the Pilot episode and analyze how the show establishes its core formula.</p>
        <p>Identify the three essential components: Tool Time chaos, family conflict, and Wilson's wisdom.</p>
        <p>How does the pilot create the template for 203 more episodes?</p>
        <p><strong>Worth:</strong> $2,500 Home Equity Dollars</p>
      ]]></description>
    </assignment>

    <!-- Module 2: Great Race Analysis -->
    <assignment identifier="ttc_mod02">
      <title>Tool Time Challenge 02: The Great Race Analysis</title>
      <points_possible>2500</points_possible>
      <grading_type>points</grading_type>
      <submission_types>online_text_entry,online_upload</submission_types>
      <description><![CDATA[
        <p>Compare Tim's approach to Bob Vila's methodology in "The Great Race" episode.</p>
        <p>Analyze 90s masculinity, DIY culture, and the tension between enthusiasm and expertise.</p>
        <p><strong>Worth:</strong> $2,500 Home Equity Dollars</p>
      ]]></description>
    </assignment>

    <!-- Module 4: Marriage Communication -->
    <assignment identifier="ttc_mod04">
      <title>Tool Time Challenge 04: Marriage Communication Analysis</title>
      <points_possible>2500</points_possible>
      <grading_type>points</grading_type>
      <submission_types>online_text_entry,online_upload</submission_types>
      <description><![CDATA[
        <p>Analyze Tim and Jill's communication patterns across Season 4.</p>
        <p>How does the show portray marital conflict resolution?</p>
        <p><strong>Worth:</strong> $2,500 Home Equity Dollars</p>
      ]]></description>
    </assignment>

    <!-- Module 6: Cultural Analysis -->
    <assignment identifier="ttc_mod06">
      <title>Tool Time Challenge 06: 90s Cultural Analysis</title>
      <points_possible>2500</points_possible>
      <grading_type>points</grading_type>
      <submission_types>online_text_entry,online_upload</submission_types>
      <description><![CDATA[
        <p>Examine Home Improvement's peak cultural impact during Season 6.</p>
        <p>How did the show reflect and shape 90s American values?</p>
        <p><strong>Worth:</strong> $2,500 Home Equity Dollars</p>
      ]]></description>
    </assignment>

    <!-- Module 8: Finale Analysis -->
    <assignment identifier="ttc_mod08">
      <title>Tool Time Challenge 08: Series Finale Analysis</title>
      <points_possible>2500</points_possible>
      <grading_type>points</grading_type>
