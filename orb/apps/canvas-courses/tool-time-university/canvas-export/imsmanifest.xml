    <schema>IMS Common Cartridge</schema>
    <schemaversion>1.1.0</schemaversion>
    <lomimscc:lom>
      <lomimscc:general>
        <lomimscc:title>
          <lomimscc:string language="en-US">Tool Time University: The Complete Home Improvement Experience</lomimscc:string>
        </lomimscc:title>
        <lomimscc:description>
          <lomimscc:string language="en-US">An 8-module deep dive into the beloved ABC sitcom Home Improvement (1991-1999). Explore character development, cultural impact, and the philosophy of MORE POWER through lessons, quizzes, discussions, and creative projects. Earn Home Equity Points on your journey from Weekend Warrior to Master Craftsman.</lomimscc:string>
        </lomimscc:description>
        <lomimscc:keyword>
          <lomimscc:string language="en-US">Home Improvement</lomimscc:string>
        </lomimscc:keyword>
        <lomimscc:keyword>
          <lomimscc:string language="en-US">Tim Allen</lomimscc:string>
        </lomimscc:keyword>
        <lomimscc:keyword>
          <lomimscc:string language="en-US">Television Studies</lomimscc:string>
        </lomimscc:keyword>
        <lomimscc:keyword>
          <lomimscc:string language="en-US">90s Sitcoms</lomimscc:string>
        </lomimscc:keyword>
        <lomimscc:keyword>
          <lomimscc:string language="en-US">Pop Culture</lomimscc:string>
        </lomimscc:keyword>
      </lomimscc:general>
    </lomimscc:lom>
  </metadata>

