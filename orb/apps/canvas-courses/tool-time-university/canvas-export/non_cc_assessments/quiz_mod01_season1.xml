          </material>
          <response_lid ident="response_q2" rcardinality="Single">
            <render_choice shuffle="No">
              <response_label ident="q2_a">
                <material><mattext texttype="text/plain">Courteney Cox</mattext></material>
              </response_label>
              <response_label ident="q2_b">
                <material><mattext texttype="text/plain">Frances Fisher</mattext></material>
              </response_label>
              <response_label ident="q2_c">
                <material><mattext texttype="text/plain">Mary Stuart Masterson</mattext></material>
              </response_label>
              <response_label ident="q2_d">
                <material><mattext texttype="text/plain">Lea Thompson</mattext></material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>

        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition title="correct" continue="No">
            <conditionvar>
              <varequal respident="response_q2">q2_b</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_correct_fb"/>
          </respcondition>
          <respcondition title="incorrect" continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_incorrect_fb"/>
          </respcondition>
        </resprocessing>

        <itemfeedback ident="q2_correct_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Correct! Al would be proud!</strong><br/>
              Frances Fisher filmed the original unaired pilot. After test audiences responded poorly to the chemistry, Patricia Richardson was cast instead.
            ]]></mattext>
          </material>
        </itemfeedback>
        <itemfeedback ident="q2_incorrect_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>I don't think so, Tim...</strong><br/>
              The correct answer is <em>Frances Fisher</em>. She filmed the original pilot, but Patricia Richardson was recast after test screenings.
            ]]></mattext>
          </material>
        </itemfeedback>
      </item>

