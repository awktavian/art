  <assessment ident="quiz_mod01_season1" title="Season 1 Trivia Challenge">
    <qtimetadata>
      <qtimetadatafield>
        <fieldlabel>cc_profile</fieldlabel>
        <fieldentry>cc.exam.v0p1</fieldentry>
      </qtimetadatafield>
      <qtimetadatafield>
        <fieldlabel>qmd_assessmenttype</fieldlabel>
        <fieldentry>Examination</fieldentry>
      </qtimetadatafield>
      <qtimetadatafield>
        <fieldlabel>qmd_scoringpermitted</fieldlabel>
        <fieldentry>Yes</fieldentry>
      </qtimetadatafield>
      <qtimetadatafield>
        <fieldlabel>qmd_timelimit</fieldlabel>
        <fieldentry>30</fieldentry>
      </qtimetadatafield>
      <qtimetadatafield>
        <fieldlabel>cc_maxattempts</fieldlabel>
        <fieldentry>3</fieldentry>
      </qtimetadatafield>
    </qtimetadata>

    <rubric>
      <material>
        <mattext texttype="text/html"><![CDATA[
          <h3>Season 1 Trivia Challenge</h3>
          <p>Test your knowledge of Home Improvement Season 1 (1991-1992). 10 questions covering the pilot episode, cast origins, and early show dynamics.</p>
          <p><strong>Worth:</strong> $750 Home Equity Dollars</p>
          <p><strong>Time Limit:</strong> 30 minutes</p>
          <p><strong>Attempts:</strong> 3 (highest score counts)</p>
        ]]></mattext>
      </material>
    </rubric>

    <section ident="section_season1" title="Season 1 Questions">

      <!-- Question 1: Original Title -->
      <item ident="q1_original_title" title="Original Show Title">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_choice.v0p1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>cc_weighting</fieldlabel>
              <fieldentry>75</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>

        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[
              What was the original working title for "Home Improvement" before legal issues forced a name change?
            ]]></mattext>
          </material>
          <response_lid ident="response_q1" rcardinality="Single">
            <render_choice shuffle="No">
              <response_label ident="q1_a">
                <material><mattext texttype="text/plain">Power Up!</mattext></material>
              </response_label>
              <response_label ident="q1_b">
                <material><mattext texttype="text/plain">Hammer Time</mattext></material>
              </response_label>
              <response_label ident="q1_c">
                <material><mattext texttype="text/plain">Tool Time</mattext></material>
              </response_label>
              <response_label ident="q1_d">
                <material><mattext texttype="text/plain">More Power</mattext></material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>

        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition title="correct" continue="No">
            <conditionvar>
              <varequal respident="response_q1">q1_b</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_correct_fb"/>
          </respcondition>
          <respcondition title="incorrect" continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_incorrect_fb"/>
          </respcondition>
        </resprocessing>

        <itemfeedback ident="q1_correct_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Correct! ARUH ARUH ARUH!</strong><br/>
              The show was originally named "Hammer Time" after MC Hammer's catchphrase, but legal concerns led to the change to "Home Improvement."
            ]]></mattext>
          </material>
        </itemfeedback>
        <itemfeedback ident="q1_incorrect_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Not quite, Tim...</strong><br/>
              The correct answer is <em>Hammer Time</em>. The show was named after MC Hammer's catchphrase, but legal issues forced the name change.
            ]]></mattext>
          </material>
        </itemfeedback>
      </item>

