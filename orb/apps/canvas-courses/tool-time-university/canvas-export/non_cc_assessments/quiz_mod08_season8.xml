    <rubric>
      <material>
        <mattext texttype="text/html"><![CDATA[
          <h3>Finale & Legacy</h3>
          <p>Test your knowledge of Home Improvement Season 8 (1998-1999) and the series finale. 10 questions covering the end of the show, behind-the-scenes decisions, and lasting legacy.</p>
          <p><strong>Worth:</strong> 75 Home Equity Dollars</p>
          <p><strong>Time Limit:</strong> 30 minutes</p>
          <p><strong>Attempts:</strong> 3 (highest score counts)</p>
        ]]></mattext>
      </material>
    </rubric>

    <section ident="section_season8" title="Season 8 Questions">

      <!-- Question 1: Season 9 Money -->
      <item ident="q1_season9_money" title="Season 9 Money">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_choice.v0p1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>cc_weighting</fieldlabel>
              <fieldentry>75</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>

        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[
              How much money did Tim Allen and Patricia Richardson reportedly turn down COMBINED to do a ninth season?
            ]]></mattext>
          </material>
          <response_lid ident="response_q1" rcardinality="Single">
            <render_choice shuffle="No">
              <response_label ident="q1_a">
                <material><mattext texttype="text/plain">$25 million</mattext></material>
              </response_label>
              <response_label ident="q1_b">
                <material><mattext texttype="text/plain">$50 million</mattext></material>
              </response_label>
              <response_label ident="q1_c">
                <material><mattext texttype="text/plain">$75 million</mattext></material>
              </response_label>
              <response_label ident="q1_d">
                <material><mattext texttype="text/plain">$100 million</mattext></material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>

        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition title="correct" continue="No">
            <conditionvar>
              <varequal respident="response_q1">q1_c</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_correct_fb"/>
          </respcondition>
          <respcondition title="incorrect" continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_incorrect_fb"/>
          </respcondition>
        </resprocessing>

        <itemfeedback ident="q1_correct_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>$75 million turned down!</strong><br/>
              Tim Allen was offered $50 million, Patricia Richardson $25 million. Both said no, choosing artistic integrity over another massive payday. Remarkable in television history.
            ]]></mattext>
          </material>
        </itemfeedback>
        <itemfeedback ident="q1_incorrect_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Even more money!</strong><br/>
              The correct answer is <em>$75 million</em> combined - $50M for Tim Allen, $25M for Patricia Richardson. They both said no.
            ]]></mattext>
          </material>
        </itemfeedback>
      </item>

