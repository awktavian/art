          <h3>Season 2 Knowledge</h3>
          <p>Test your knowledge of Home Improvement Season 2 (1992-1993). 10 questions covering The Great Race, Bob Vila rivalry, and the show's rise to prominence.</p>
          <p><strong>Worth:</strong> 75 Home Equity Dollars</p>
          <p><strong>Time Limit:</strong> 30 minutes</p>
          <p><strong>Attempts:</strong> 3 (highest score counts)</p>
        ]]></mattext>
      </material>
    </rubric>

    <section ident="section_season2" title="Season 2 Questions">

      <!-- Question 1: Tool Time Girl (Fill in the Blank) -->
      <item ident="q1_tool_time_girl" title="Tool Time Girl">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.fib.v0p1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>cc_weighting</fieldlabel>
              <fieldentry>75</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>

        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[
              During Season 2, the Tool Time Girl was _______, played by Pamela Anderson. This was her final full season before leaving for Baywatch. (Enter first name)
            ]]></mattext>
          </material>
          <response_str ident="response_q1" rcardinality="Single">
            <render_fib fibtype="String" prompt="Box" rows="1" columns="20"/>
          </response_str>
        </presentation>

        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition title="correct" continue="No">
            <conditionvar>
              <varequal respident="response_q1" case="No">Lisa</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_correct_fb"/>
          </respcondition>
          <respcondition title="incorrect" continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_incorrect_fb"/>
          </respcondition>
        </resprocessing>

        <itemfeedback ident="q1_correct_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>TOOL TIME! Correct!</strong><br/>
              Lisa, played by Pamela Anderson, was the original Tool Time Girl for Seasons 1-2. She left to star in Baywatch and was replaced by Heidi (Debbe Dunning) starting in Season 3.
            ]]></mattext>
          </material>
        </itemfeedback>
        <itemfeedback ident="q1_incorrect_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Time for a rewatch!</strong><br/>
              The correct answer is <em>Lisa</em>. Lisa was Tool Time's assistant during Seasons 1-2, played by Pamela Anderson.
            ]]></mattext>
          </material>
        </itemfeedback>
      </item>

