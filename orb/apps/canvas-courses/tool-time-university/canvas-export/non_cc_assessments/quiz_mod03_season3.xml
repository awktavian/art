    <rubric>
      <material>
        <mattext texttype="text/html"><![CDATA[
          <h3>Peak Tool Time</h3>
          <p>Test your knowledge of Home Improvement Season 3 (1993-1994). 10 questions covering the show's peak ratings, grunt evolution, and the Coach crossover.</p>
          <p><strong>Worth:</strong> 75 Home Equity Dollars</p>
          <p><strong>Time Limit:</strong> 30 minutes</p>
          <p><strong>Attempts:</strong> 3 (highest score counts)</p>
        ]]></mattext>
      </material>
    </rubric>

    <section ident="section_season3" title="Season 3 Questions">

      <!-- Question 1: Grunt Types -->
      <item ident="q1_grunt_types" title="Grunt Types">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_choice.v0p1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>cc_weighting</fieldlabel>
              <fieldentry>75</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>

        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[
              Season 3 introduced new grunt variations. Which of these is NOT one of Tim's documented grunt types?
            ]]></mattext>
          </material>
          <response_lid ident="response_q1" rcardinality="Single">
            <render_choice shuffle="No">
              <response_label ident="q1_a">
                <material><mattext texttype="text/plain">The Contemplative Grunt</mattext></material>
              </response_label>
              <response_label ident="q1_b">
                <material><mattext texttype="text/plain">The Injured-But-Pretending-It's-Fine Grunt</mattext></material>
              </response_label>
              <response_label ident="q1_c">
                <material><mattext texttype="text/plain">The Romantic Serenade Grunt</mattext></material>
              </response_label>
              <response_label ident="q1_d">
                <material><mattext texttype="text/plain">The Double-Reverb Grunt</mattext></material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>

        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition title="correct" continue="No">
            <conditionvar>
              <varequal respident="response_q1">q1_c</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_correct_fb"/>
          </respcondition>
          <respcondition title="incorrect" continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_incorrect_fb"/>
          </respcondition>
        </resprocessing>

        <itemfeedback ident="q1_correct_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>ARUH ARUH! You know your grunts!</strong><br/>
              The Contemplative Grunt, Injured-But-Pretending Grunt, and rare Double-Reverb Grunt were all part of Tim's Season 3 vocal evolution. The Romantic Serenade Grunt? Not a thing... yet.
            ]]></mattext>
          </material>
        </itemfeedback>
        <itemfeedback ident="q1_incorrect_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Wrong grunt classification!</strong><br/>
              The correct answer is <em>The Romantic Serenade Grunt</em> - that one doesn't exist. The others are documented Tim Taylor vocalizations!
            ]]></mattext>
          </material>
        </itemfeedback>
      </item>

