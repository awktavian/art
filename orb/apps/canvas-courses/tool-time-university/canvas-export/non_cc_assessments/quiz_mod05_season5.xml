    <rubric>
      <material>
        <mattext texttype="text/html"><![CDATA[
          <h3>Mature Storylines</h3>
          <p>Test your knowledge of Home Improvement Season 5 (1995-1996). 10 questions covering mature themes, character development, and Wilson's wisdom.</p>
          <p><strong>Worth:</strong> 75 Home Equity Dollars</p>
          <p><strong>Time Limit:</strong> 30 minutes</p>
          <p><strong>Attempts:</strong> 3 (highest score counts)</p>
        ]]></mattext>
      </material>
    </rubric>

    <section ident="section_season5" title="Season 5 Questions">

      <!-- Question 1: Storytelling Ability -->
      <item ident="q1_storytelling" title="Storytelling Ability">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_choice.v0p1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>cc_weighting</fieldlabel>
              <fieldentry>75</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>

        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[
              What did Season 5 prove about Home Improvement's storytelling ability?
            ]]></mattext>
          </material>
          <response_lid ident="response_q1" rcardinality="Single">
            <render_choice shuffle="No">
              <response_label ident="q1_a">
                <material><mattext texttype="text/plain">It could only do slapstick comedy</mattext></material>
              </response_label>
              <response_label ident="q1_b">
                <material><mattext texttype="text/plain">It could deliver complex family drama while maintaining its comedic core</mattext></material>
              </response_label>
              <response_label ident="q1_c">
                <material><mattext texttype="text/plain">It needed more Tool Time segments</mattext></material>
              </response_label>
              <response_label ident="q1_d">
                <material><mattext texttype="text/plain">The format was outdated</mattext></material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>

        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition title="correct" continue="No">
            <conditionvar>
              <varequal respident="response_q1">q1_b</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_correct_fb"/>
          </respcondition>
          <respcondition title="incorrect" continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_incorrect_fb"/>
          </respcondition>
        </resprocessing>

        <itemfeedback ident="q1_correct_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Show maturation!</strong><br/>
              By Season 5, Home Improvement had transcended its "man vs. power tools" premise. The show delivered complex family drama wrapped in comfortable comedy.
            ]]></mattext>
          </material>
        </itemfeedback>
        <itemfeedback ident="q1_incorrect_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Think deeper!</strong><br/>
              The correct answer is <em>It could deliver complex family drama while maintaining its comedic core</em>. The show evolved significantly.
            ]]></mattext>
          </material>
        </itemfeedback>
      </item>

