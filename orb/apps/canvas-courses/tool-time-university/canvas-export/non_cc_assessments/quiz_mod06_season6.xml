    <rubric>
      <material>
        <mattext texttype="text/html"><![CDATA[
          <h3>Peak Cultural Impact</h3>
          <p>Test your knowledge of Home Improvement Season 6 (1996-1997). 10 questions covering the show's zenith, character development, and landmark episodes.</p>
          <p><strong>Worth:</strong> 75 Home Equity Dollars</p>
          <p><strong>Time Limit:</strong> 30 minutes</p>
          <p><strong>Attempts:</strong> 3 (highest score counts)</p>
        ]]></mattext>
      </material>
    </rubric>

    <section ident="section_season6" title="Season 6 Questions">

      <!-- Question 1: Al's Love Interest (Fill in the Blank) -->
      <item ident="q1_al_love" title="Al's Love Interest">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.fib.v0p1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>cc_weighting</fieldlabel>
              <fieldentry>75</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>

        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[
              Season 6 finally let Al be more than Tim's straight man. He found lasting love with a woman named _______.
            ]]></mattext>
          </material>
          <response_str ident="response_q1" rcardinality="Single">
            <render_fib fibtype="String" prompt="Box" rows="1" columns="20"/>
          </response_str>
        </presentation>

        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition title="correct" continue="No">
            <conditionvar>
              <varequal respident="response_q1" case="No">ilene</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_correct_fb"/>
          </respcondition>
          <respcondition title="incorrect" continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_incorrect_fb"/>
          </respcondition>
        </resprocessing>

        <itemfeedback ident="q1_correct_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Al found love!</strong><br/>
              Al and Ilene's relationship showed audiences a complete character capable of vulnerability, growth, and genuine happiness. After years of failed relationships and mother jokes, Al finally found his match.
            ]]></mattext>
          </material>
        </itemfeedback>
        <itemfeedback ident="q1_incorrect_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Different love interest!</strong><br/>
              The correct answer is <em>Ilene</em>. Al and Ilene's relationship was a highlight of Season 6.
            ]]></mattext>
          </material>
        </itemfeedback>
      </item>

      <!-- Question 2: Jill's Birthday -->
      <item ident="q2_jills_birthday" title="Jill's Birthday">
