    <rubric>
      <material>
        <mattext texttype="text/html"><![CDATA[
          <h3>The Home Stretch</h3>
          <p>Test your knowledge of Home Improvement Season 7 (1997-1998). 10 questions covering major cast changes, character development, and Wilson's philosophy.</p>
          <p><strong>Worth:</strong> 75 Home Equity Dollars</p>
          <p><strong>Time Limit:</strong> 30 minutes</p>
          <p><strong>Attempts:</strong> 3 (highest score counts)</p>
        ]]></mattext>
      </material>
    </rubric>

    <section ident="section_season7" title="Season 7 Questions">

      <!-- Question 1: Randy's Destination (Fill in the Blank) -->
      <item ident="q1_randy_destination" title="Randy's Destination">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.fib.v0p1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>cc_weighting</fieldlabel>
              <fieldentry>75</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>

        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[
              Randy's departure was written as him leaving to study the rainforest in _______ (country).
            ]]></mattext>
          </material>
          <response_str ident="response_q1" rcardinality="Single">
            <render_fib fibtype="String" prompt="Box" rows="1" columns="20"/>
          </response_str>
        </presentation>

        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition title="correct" continue="No">
            <conditionvar>
              <varequal respident="response_q1" case="No">costa rica</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_correct_fb"/>
          </respcondition>
          <respcondition title="incorrect" continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_incorrect_fb"/>
          </respcondition>
        </resprocessing>

        <itemfeedback ident="q1_correct_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Environmental activism!</strong><br/>
              Randy's decision to spend a year in Costa Rica studying the rainforest represented the culmination of his character arc - from curious kid to principled young man willing to act on his beliefs.
            ]]></mattext>
          </material>
        </itemfeedback>
        <itemfeedback ident="q1_incorrect_fb">
          <material>
            <mattext texttype="text/html"><![CDATA[
              <strong>Different destination!</strong><br/>
              The correct answer is <em>Costa Rica</em>. The environmental program allowed for potential returns while respecting the actor's decision to leave.
            ]]></mattext>
          </material>
        </itemfeedback>
      </item>

