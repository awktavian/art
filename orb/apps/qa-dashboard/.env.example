# =============================================================================
# Kagami QA Dashboard - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Never commit .env.local to version control!

# =============================================================================
# API Configuration
# =============================================================================

# Base URL for the QA Pipeline server API
# In development, this defaults to http://localhost:8080 if not set
# In production, set this to your deployed API endpoint
NEXT_PUBLIC_API_URL=http://localhost:8080

# =============================================================================
# API Endpoints Reference
# =============================================================================
# The following endpoints should be available on your QA Pipeline server:
#
# GET  /api/platforms          - List all platform summaries
# GET  /api/journeys           - List user journeys (supports query params)
#      Query params:
#        - platform: Filter by platform (ios, android, visionos, etc.)
#        - status: Filter by test status (pass, fail, in_progress, etc.)
#        - branch: Filter by git branch
#        - commitSha: Filter by commit SHA
#        - limit: Max results to return
#        - offset: Pagination offset
# GET  /api/journeys/:id       - Get single journey by ID
# GET  /api/journeys/:id/history - Get run history for a journey
# GET  /api/analysis/issues    - Get AI-detected issues
# GET  /api/metrics/trends     - Get trend data
#      Query params:
#        - days: Number of days of data (default: 14)
# GET  /api/health             - Health check endpoint

# =============================================================================
# Development Notes
# =============================================================================
# When the API is unavailable in development mode, the dashboard will
# automatically fall back to mock data. This allows frontend development
# without requiring a running backend server.
#
# To force real API usage even in development, ensure your QA Pipeline
# server is running and accessible at the configured NEXT_PUBLIC_API_URL.
