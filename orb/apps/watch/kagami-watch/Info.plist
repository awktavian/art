<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    鏡 Kagami Watch — Info.plist

    Required Info.plist entries for HealthKit access.

    Include these entries in your Xcode project's Info.plist.

    Created: December 30, 2025
-->
<plist version="1.0">
<dict>
    <!-- App Info -->
    <key>CFBundleName</key>
    <string>Kagami</string>
    <key>CFBundleIdentifier</key>
    <string>com.kagami.watch</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>WKWatchKitApp</key>
    <true/>

    <!-- HealthKit Usage Description (REQUIRED) -->
    <key>NSHealthShareUsageDescription</key>
    <string>Kagami uses your health data to provide personalized home automation. Your heart rate, activity, and sleep patterns help me understand your state and adjust lighting, temperature, and scenes accordingly. For example, if you're sleeping poorly, I might suggest a relaxing evening routine.</string>

    <!-- Specific health data descriptions -->
    <key>NSHealthClinicalHealthRecordsShareUsageDescription</key>
    <string>Kagami can read clinical health records to provide deeper wellness insights and adapt your home environment to support your health goals.</string>

    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>processing</string>
    </array>

    <!-- Minimum watchOS Version -->
    <key>MinimumOSVersion</key>
    <string>10.0</string>
</dict>
</plist>
