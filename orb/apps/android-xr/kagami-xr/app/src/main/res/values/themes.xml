<?xml version="1.0" encoding="utf-8"?>
<!--
    Kagami XR Theme - Dark (optimized for XR)

    Colony: Nexus (e4) - Integration

    Note: Using android base theme since Material3 styles come from Compose.

    h(x) >= 0. Always.
-->
<resources>
    <!-- Base application theme - Dark mode default for XR -->
    <style name="Theme.KagamiXR" parent="android:Theme.Material.NoActionBar">
        <!-- Edge-to-edge configuration -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Dark theme colors -->
        <item name="android:colorBackground">#0D0D0F</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
