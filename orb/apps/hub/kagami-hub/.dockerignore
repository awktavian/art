# ═══════════════════════════════════════════════════════════════════════════
# KAGAMI HUB — Docker Ignore
# ═══════════════════════════════════════════════════════════════════════════

# Build artifacts
target/
*.rs.bk

# Git
.git
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Documentation (not needed in image)
*.md
!README.md
docs/

# Tests
tests/
**/*_test.rs

# Development files
.env
.env.*
!.env.example

# Hardware files (not needed in Docker)
hardware/

# Scripts (except config)
scripts/
!scripts/download_models.sh

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker files (don't include in context)
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# Temporary files
*.tmp
*.log
*.cache

# OS files
.DS_Store
Thumbs.db

# Rust cache
.cargo/

# Coverage
*.gcno
*.gcda
lcov.info
