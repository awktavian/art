<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    鏡 Kagami Vision — Info.plist

    Required Info.plist entries for visionOS spatial home control.

    Updated: January 2, 2026
-->
<plist version="1.0">
<dict>
    <!-- App Info -->
    <key>CFBundleName</key>
    <string>Kagami</string>
    <key>CFBundleIdentifier</key>
    <string>com.kagami.vision</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleDisplayName</key>
    <string>Kagami</string>

    <!-- Minimum visionOS Version -->
    <key>MinimumOSVersion</key>
    <string>1.0</string>

    <!-- HealthKit Usage Description (REQUIRED) -->
    <key>NSHealthShareUsageDescription</key>
    <string>Kagami uses your health data to create a personalized spatial experience. Your activity levels and wellness metrics help me adjust the ambient environment in your Vision Pro, showing relevant health insights and adapting suggestions to your current state.</string>

    <!-- Microphone Usage - Voice Commands (REQUIRED) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Kagami uses the microphone for voice commands. Say "Hey Kagami" followed by commands like "Movie mode" or "Lights to 50 percent" to control your smart home hands-free.</string>

    <!-- Speech Recognition - Voice Processing (REQUIRED) -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Kagami uses on-device speech recognition to understand your voice commands and control your smart home. Your voice is processed locally and never sent to external servers.</string>

    <!-- Camera Usage - ARKit Spatial Tracking (REQUIRED for visionOS) -->
    <key>NSCameraUsageDescription</key>
    <string>Kagami uses spatial tracking to understand your environment and anchor smart home controls to your physical space. No images are stored or transmitted.</string>

    <!-- Hand Tracking Usage (REQUIRED for visionOS) -->
    <key>NSHandsTrackingUsageDescription</key>
    <string>Kagami uses hand tracking for natural gesture control of your smart home. Pinch to select, swipe to adjust brightness, and use two-hand gestures to scale the interface.</string>

    <!-- World Sensing Usage (REQUIRED for visionOS) -->
    <key>NSWorldSensingUsageDescription</key>
    <string>Kagami uses world sensing to place control panels in your physical space and remember their positions. Your spatial data stays on-device.</string>

    <!-- Local Network Usage - Smart Home Server -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Kagami connects to your local smart home server to control lights, shades, and other devices. No data is sent outside your home network.</string>

    <!-- Bonjour Services for mDNS Discovery -->
    <key>NSBonjourServices</key>
    <array>
        <string>_kagami._tcp</string>
        <string>_http._tcp</string>
    </array>

    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>fetch</string>
        <string>processing</string>
        <string>remote-notification</string>
    </array>

    <!-- App Transport Security - Local Network Exception -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>kagami.local</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- Supported Interface Orientations (visionOS) -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Launch Screen -->
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string>AccentColor</string>
    </dict>

    <!-- Scene Configuration for visionOS -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
        <key>UISceneConfigurations</key>
        <dict/>
    </dict>

    <!-- Required Device Capabilities -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
</dict>
</plist>
