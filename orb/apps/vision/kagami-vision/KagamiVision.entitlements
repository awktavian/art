<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    鏡 Kagami Vision — Entitlements

    Required entitlements for visionOS spatial home control.

    Add this to your Xcode project under:
    Signing & Capabilities > + Capability

    Updated: January 2, 2026
-->
<plist version="1.0">
<dict>
    <!-- HealthKit Access - Read health data from paired iPhone -->
    <key>com.apple.developer.healthkit</key>
    <true/>
    <key>com.apple.developer.healthkit.access</key>
    <array>
        <string>health-records</string>
    </array>
    <key>com.apple.developer.healthkit.background-delivery</key>
    <true/>

    <!-- ARKit - Hand tracking and spatial anchors -->
    <key>com.apple.developer.arkit</key>
    <true/>

    <!-- Spatial Computing - Immersive spaces and world sensing -->
    <key>com.apple.developer.spatial-computing</key>
    <true/>

    <!-- World Sensing - ARKit world tracking -->
    <key>com.apple.developer.world-sensing</key>
    <true/>

    <!-- Hand Tracking - Gesture recognition -->
    <key>com.apple.developer.hand-tracking</key>
    <true/>

    <!-- SharePlay - Shared spatial experiences -->
    <key>com.apple.developer.group-session</key>
    <true/>

    <!-- Network Access - Local home server communication -->
    <key>com.apple.developer.networking.networkextension</key>
    <array>
        <string>app-proxy-provider</string>
    </array>

    <!-- App Groups - Shared data with widgets -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.kagami.shared</string>
    </array>

    <!-- Keychain Sharing - Secure credential storage -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.kagami.vision</string>
        <string>$(AppIdentifierPrefix)com.kagami.shared</string>
    </array>
</dict>
</plist>
