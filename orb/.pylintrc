[MAIN]
# Python code to execute
init-hook='import sys; sys.path.append(".")'

# Files or directories to analyze
recursive=yes

# Use multiple processes to speed up Pylint
jobs=4

[MESSAGES CONTROL]
# Disable specific warnings
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-many-instance-attributes,
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-few-public-methods,
    invalid-name,
    fixme,
    duplicate-code,
    import-outside-toplevel,
    broad-except,
    logging-fstring-interpolation,
    line-too-long,
    protected-access,
    abstract-method,
    unused-argument,
    redefined-outer-name,
    consider-using-f-string

[FORMAT]
# Maximum number of characters on a single line
max-line-length=120

# Maximum number of lines in a module
max-module-lines=2000

[DESIGN]
# Maximum number of arguments for function / method
max-args=10

# Maximum number of attributes for a class
max-attributes=15

# Maximum number of local variables for function / method
max-locals=20

[TYPECHECK]
# List of members which are set dynamically
generated-members=torch.*,numpy.*

[SIMILARITIES]
# Minimum lines number of a similarity
min-similarity-lines=10

[BASIC]
# Good variable names
good-names=i,j,k,x,y,z,t,e,f,g,h,q,u,v,w,a,b,c,d,n,m,p,s,r,_

[IMPORTS]
# Allow wildcard imports from typing
allow-wildcard-with-all=yes
