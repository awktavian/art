{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Kagami Design System — Motion Tokens",
  "version": "1.0.0",

  "duration": {
    "description": "Standard animation durations (milliseconds)",
    "instant": 89,
    "fast": 144,
    "normal": 233,
    "slow": 377,
    "slower": 610,
    "slowest": 987
  },

  "easing": {
    "description": "Standard easing curves (cubic-bezier)",
    "snap": {
      "bezier": [0.7, 0, 0.3, 1],
      "description": "Sudden snap"
    },
    "sharp": {
      "bezier": [0.4, 0, 0.2, 1],
      "description": "Decisive"
    },
    "bounce": {
      "bezier": [0.34, 1.2, 0.64, 1],
      "description": "Overshoot"
    },
    "elastic": {
      "bezier": [0.68, -0.2, 0.32, 1.2],
      "description": "Complex oscillation"
    },
    "smooth": {
      "bezier": [0.16, 1, 0.3, 1],
      "description": "Default expo-out"
    }
  },

  "spring": {
    "description": "Spring animation parameters",
    "micro": { "damping": 0.8, "stiffness": "high", "response": 0.089 },
    "fast": { "damping": 0.75, "stiffness": "mediumLow", "response": 0.144 },
    "default": { "damping": 0.7, "stiffness": "medium", "response": 0.233 },
    "soft": { "damping": 0.65, "stiffness": "low", "response": 0.377 }
  }
}
