{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Kagami Design System — Glass Effect Tokens",
  "version": "1.0.0",

  "glass": {
    "description": "Apple-style glassmorphism base",
    "blur": {
      "thin": 10,
      "regular": 20,
      "thick": 40
    },
    "transparency": {
      "min": 0.70,
      "default": 0.80,
      "max": 0.90
    },
    "border": {
      "width": 1,
      "opacity": 0.10
    },
    "shadow": {
      "offset": [0, 2],
      "blur": 10,
      "opacity": 0.10
    }
  },

  "spectral": {
    "description": "Spectral shimmer effect",
    "phases": {
      "description": "7 color phases",
      "count": 7
    },
    "shimmer": {
      "duration": 8000,
      "opacity": {
        "idle": 0,
        "hover": 0.3,
        "active": 0.5
      }
    },
    "border": {
      "width": 2,
      "duration": 6000
    }
  },

  "caustics": {
    "description": "Animated rainbow light patterns",
    "layers": 3,
    "durations": [25000, 30000, 35000],
    "opacity": {
      "min": 0.4,
      "max": 0.7
    }
  },

  "chromatic": {
    "description": "Chromatic aberration on hover",
    "offset": 2,
    "opacity": 0.5
  },

  "ripple": {
    "description": "Click ripple effect",
    "duration": 800,
    "scale": 4,
    "colors": ["spark", "flow", "beacon", "crystal"]
  },

  "particles": {
    "description": "Floating spectral particles",
    "count": 21,
    "duration": 15000,
    "size": 4
  },

  "zIndex": {
    "description": "Z-index layers for effects",
    "caustics": -10,
    "content": 1,
    "overlay": 100,
    "cursor": 1000
  }
}
