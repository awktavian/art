{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Kagami Design System — Spacing & Layout Tokens",
  "version": "1.0.0",

  "spacing": {
    "description": "8px grid system",
    "unit": 8,
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48
  },

  "radius": {
    "description": "Border radius tokens",
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "full": 9999
  },

  "touchTarget": {
    "description": "Minimum touch target sizes (dp/pt)",
    "minimum": 48,
    "recommended": 56
  }
}
