{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Kagami Design System — Color Tokens",
  "version": "1.0.0",

  "void": {
    "description": "Void Palette (Backgrounds)",
    "void": "#07060B",
    "voidWarm": "#0D0A0F",
    "obsidian": "#12101A",
    "voidLight": "#1a1820",
    "carbon": "#252330"
  },

  "colony": {
    "description": "Core Brand Colors",
    "spark":   { "hex": "#ff6b35", "rgb": [255, 107, 53],  "name": "Ideation" },
    "forge":   { "hex": "#d4af37", "rgb": [212, 175, 55],  "name": "Implementation" },
    "flow":    { "hex": "#4ecdc4", "rgb": [78, 205, 196],  "name": "Adaptation" },
    "nexus":   { "hex": "#9b7ebd", "rgb": [155, 126, 189], "name": "Integration" },
    "beacon":  { "hex": "#f59e0b", "rgb": [245, 158, 11],  "name": "Planning" },
    "grove":   { "hex": "#7eb77f", "rgb": [126, 183, 127], "name": "Research" },
    "crystal": { "hex": "#67d4e4", "rgb": [103, 212, 228], "name": "Verification" }
  },

  "status": {
    "description": "Status Colors",
    "success": "#00ff88",
    "error": "#ff4444",
    "warning": "#ffd700"
  },

  "text": {
    "description": "Text Colors",
    "primary": "#f5f0e8",
    "secondary": { "base": "#f5f0e8", "opacity": 0.65 },
    "tertiary": { "base": "#f5f0e8", "opacity": 0.35 }
  },

  "mode": {
    "description": "Mode Colors (Colony-Aligned)",
    "ask": "grove",
    "plan": "beacon",
    "agent": "forge"
  },

  "highContrast": {
    "description": "WCAG AAA High Contrast Overrides",
    "background": "#000000",
    "surface": "#121212",
    "text": "#FFFFFF",
    "textSecondary": "#E0E0E0",
    "accent": "#00FFFF",
    "border": "#FFFFFF",
    "colony": {
      "spark": "#FF7744",
      "forge": "#FFD700",
      "flow": "#00FFFF",
      "nexus": "#CC99FF",
      "beacon": "#FFBB00",
      "grove": "#00FF88",
      "crystal": "#00EEFF"
    }
  }
}
