{
  "version": 2,
  "description": "Metrics contract for Kagami observability - defines metrics used by dashboards",
  "updated": "2025-12-22",
  "metrics": [
    {
      "name": "kagami_agent_phase_duration_seconds",
      "type": "histogram",
      "labels": ["phase"],
      "description": "Duration of agent execution phases (perceive, model, simulate, act, verify, converge)"
    },
    {
      "name": "kagami_quality_gate_failures",
      "type": "counter",
      "labels": ["gate"],
      "description": "Quality gate failures by gate type"
    },
    {
      "name": "kagami_receipts_total",
      "type": "counter",
      "labels": ["phase", "status"],
      "description": "Total receipts by phase and status"
    },
    {
      "name": "kagami_idempotency_checks_total",
      "type": "counter",
      "labels": ["status"],
      "description": "Idempotency checks performed"
    },
    {
      "name": "kagami_background_agent_suggestions_total",
      "type": "counter",
      "labels": ["agent_type"],
      "description": "Background agent suggestions"
    },
    {
      "name": "kagami_background_agent_runs_total",
      "type": "counter",
      "labels": ["agent_type"],
      "description": "Background agent executions"
    },
    {
      "name": "kagami_colony_population",
      "type": "gauge",
      "labels": ["domain", "status"],
      "description": "Colony population by domain"
    },
    {
      "name": "kagami_colony_tasks_completed_total",
      "type": "counter",
      "labels": ["domain"],
      "description": "Tasks completed by colony domain"
    },
    {
      "name": "kagami_colony_tasks_failed_total",
      "type": "counter",
      "labels": ["domain"],
      "description": "Tasks failed by colony domain"
    },
    {
      "name": "kagami_colony_task_success_rate",
      "type": "gauge",
      "labels": ["domain"],
      "description": "Task success rate by colony (0-1)"
    },
    {
      "name": "kagami_colony_health_score",
      "type": "gauge",
      "labels": ["domain"],
      "description": "Colony health score (1-4)"
    },
    {
      "name": "kagami_agent_mitosis_total",
      "type": "counter",
      "labels": ["domain", "strategy"],
      "description": "Agent mitosis events"
    },
    {
      "name": "kagami_agent_apoptosis_total",
      "type": "counter",
      "labels": ["domain", "reason"],
      "description": "Agent apoptosis events"
    },
    {
      "name": "kagami_agent_fitness",
      "type": "gauge",
      "labels": ["domain"],
      "description": "Agent fitness scores by domain"
    },
    {
      "name": "kagami_agent_memory_bytes",
      "type": "gauge",
      "labels": ["agent_name"],
      "description": "Agent memory usage in bytes"
    },
    {
      "name": "kagami_agent_memory_violations_total",
      "type": "counter",
      "labels": ["agent_name", "violation_type"],
      "description": "Memory limit violations"
    },
    {
      "name": "kagami_agent_spawn_failures_total",
      "type": "counter",
      "labels": ["reason"],
      "description": "Agent spawn failures"
    },
    {
      "name": "kagami_cbf_blocks_total",
      "type": "counter",
      "labels": ["operation", "reason"],
      "description": "CBF safety blocks"
    },
    {
      "name": "kagami_cbf_agent_safety_duration_seconds",
      "type": "histogram",
      "labels": [],
      "description": "CBF safety check duration"
    },
    {
      "name": "kagami_honesty_violations_total",
      "type": "counter",
      "labels": ["evidence_type"],
      "description": "Honesty validator violations"
    },
    {
      "name": "kagami_http_requests_total",
      "type": "counter",
      "labels": ["method", "route", "status_code"],
      "description": "HTTP request count"
    },
    {
      "name": "kagami_http_request_duration_seconds",
      "type": "histogram",
      "labels": ["method", "route"],
      "description": "HTTP request latency"
    },
    {
      "name": "kagami_db_query_duration_seconds",
      "type": "histogram",
      "labels": ["operation"],
      "description": "Database query latency"
    },
    {
      "name": "kagami_db_connection_pool_size",
      "type": "gauge",
      "labels": ["state"],
      "description": "Database connection pool state"
    },
    {
      "name": "kagami_system_memory_usage",
      "type": "gauge",
      "labels": [],
      "description": "System memory usage (0-1)"
    },
    {
      "name": "kagami_system_cpu_usage",
      "type": "gauge",
      "labels": [],
      "description": "System CPU usage (0-1)"
    },
    {
      "name": "kagami_consciousness_threat_score",
      "type": "gauge",
      "labels": [],
      "description": "Threat score from consciousness (0-1)"
    },
    {
      "name": "kagami_consciousness_valence",
      "type": "gauge",
      "labels": [],
      "description": "Emotional valence (-1 to 1)"
    },
    {
      "name": "kagami_consciousness_arousal",
      "type": "gauge",
      "labels": [],
      "description": "Arousal level (-1 to 1)"
    },
    {
      "name": "kagami_consciousness_ethical_blocks_total",
      "type": "counter",
      "labels": ["reason"],
      "description": "Ethical reasoning blocks"
    },
    {
      "name": "kagami_identity_drift",
      "type": "gauge",
      "labels": [],
      "description": "Identity drift score (0-1)"
    },
    {
      "name": "kagami_emergence_synergy_score",
      "type": "gauge",
      "labels": [],
      "description": "Emergence synergy score (target >1.2)"
    },
    {
      "name": "kagami_agents_active",
      "type": "gauge",
      "labels": ["colony"],
      "description": "Active agents (alias for colony population)"
    },
    {
      "name": "kagami_agent_task_duration_seconds",
      "type": "histogram",
      "labels": ["agent_domain", "task_type"],
      "description": "Task execution duration"
    }
  ]
}
