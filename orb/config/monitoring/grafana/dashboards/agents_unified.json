{
  "dashboard": {
    "uid": "kagami-agents-unified",
    "title": "K os Agents - Unified Dashboard",
    "tags": ["kagami", "agents", "colony", "fractal", "health"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "editable": true,
    "time": {"from": "now-6h", "to": "now"},
    "panels": [
      {
        "id": 1,
        "title": "📊 Key Metrics",
        "type": "row",
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 2,
        "title": "Active Agents",
        "type": "stat",
        "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(kagami_agents_active)",
            "legendFormat": "Total Active",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 10, "color": "green"},
                {"value": 50, "color": "yellow"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Tasks Completed (24h)",
        "type": "stat",
        "gridPos": {"x": 6, "y": 1, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(increase(kagami_colony_tasks_completed_total[24h]))",
            "legendFormat": "Completed",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 100, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Task Success Rate",
        "type": "gauge",
        "gridPos": {"x": 12, "y": 1, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "avg(kagami_colony_task_success_rate) * 100",
            "legendFormat": "Success %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 80, "color": "yellow"},
                {"value": 95, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Average Task Duration (p95)",
        "type": "stat",
        "gridPos": {"x": 18, "y": 1, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(kagami_agent_task_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95 Duration",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 30, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "🧬 Colony Population & Lifecycle",
        "type": "row",
        "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 7,
        "title": "Colony Population by Domain",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "kagami_colony_population{status=\"total\"}",
            "legendFormat": "{{domain}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "lineWidth": 2
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "calcs": ["lastNotNull", "mean"]
          }
        }
      },
      {
        "id": 8,
        "title": "Agent Mitosis & Apoptosis",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(kagami_agent_mitosis_total[5m])",
            "legendFormat": "Mitosis - {{domain}}",
            "refId": "A"
          },
          {
            "expr": "rate(kagami_agent_apoptosis_total[5m])",
            "legendFormat": "Apoptosis - {{domain}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byRegexp", "options": "Mitosis.*"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}
              ]
            },
            {
              "matcher": {"id": "byRegexp", "options": "Apoptosis.*"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}
              ]
            }
          ]
        }
      },
      {
        "id": 9,
        "title": "⚡ Task Execution",
        "type": "row",
        "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 10,
        "title": "Task Completion Rate by Colony",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum by (domain) (rate(kagami_colony_tasks_completed_total[5m]))",
            "legendFormat": "{{domain}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Phase Duration (6-Phase Loop)",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(kagami_agent_phase_duration_seconds_bucket[5m])) by (le, phase))",
            "legendFormat": "{{phase}} p95",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth"
            }
          }
        }
      },
      {
        "id": 12,
        "title": "🧠 Agent Health & Fitness",
        "type": "row",
        "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 13,
        "title": "Agent Fitness by Domain",
        "type": "heatmap",
        "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "kagami_agent_fitness",
            "format": "heatmap",
            "legendFormat": "{{domain}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 14,
        "title": "Colony Health Score",
        "type": "bargauge",
        "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "kagami_colony_health_score",
            "legendFormat": "{{domain}}",
            "refId": "A"
          }
        ],
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 4,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 2, "color": "yellow"},
                {"value": 3, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 15,
        "title": "🛡️ Memory & Safety",
        "type": "row",
        "gridPos": {"x": 0, "y": 32, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 16,
        "title": "Agent Memory Usage",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 33, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "kagami_agent_memory_bytes / (1024*1024*1024)",
            "legendFormat": "{{agent_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decgbytes",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 4, "color": "yellow"},
                {"value": 8, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 17,
        "title": "Memory Violations",
        "type": "stat",
        "gridPos": {"x": 12, "y": 33, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(kagami_agent_memory_violations_total[5m]))",
            "legendFormat": "Violations/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.1, "color": "yellow"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        },
        "alert": {
          "name": "Memory Violation Alert",
          "conditions": [
            {
              "evaluator": {"params": [0], "type": "gt"},
              "query": {"params": ["A", "5m", "now"]},
              "type": "query"
            }
          ],
          "frequency": "60s",
          "handler": 1,
          "message": "🚨 Agent memory violation detected!"
        }
      },
      {
        "id": 18,
        "title": "Spawn Failures",
        "type": "stat",
        "gridPos": {"x": 18, "y": 33, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(kagami_agent_spawn_failures_total[5m]))",
            "legendFormat": "Failures/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.1, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 19,
        "title": "🔧 Consciousness & Cognition",
        "type": "row",
        "gridPos": {"x": 0, "y": 41, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 20,
        "title": "Consciousness Metrics",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 42, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "kagami_consciousness_threat_score",
            "legendFormat": "Threat Score",
            "refId": "A"
          },
          {
            "expr": "kagami_consciousness_valence",
            "legendFormat": "Valence",
            "refId": "B"
          },
          {
            "expr": "kagami_consciousness_arousal",
            "legendFormat": "Arousal",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": -1,
            "max": 1,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth"
            }
          }
        }
      },
      {
        "id": 21,
        "title": "Identity Drift",
        "type": "gauge",
        "gridPos": {"x": 12, "y": 42, "w": 6, "h": 8},
        "targets": [
          {
            "expr": "kagami_identity_drift",
            "legendFormat": "Drift Score",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.3, "color": "yellow"},
                {"value": 0.5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 22,
        "title": "Convergence Rate",
        "type": "stat",
        "gridPos": {"x": 18, "y": 42, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "rate(kagami_agent_convergence_total[5m])",
            "legendFormat": "Convergences/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.1, "color": "yellow"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 23,
        "title": "Ethical Blocks by Reason",
        "type": "piechart",
        "gridPos": {"x": 18, "y": 46, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum by (reason) (kagami_consciousness_ethical_blocks_total)",
            "legendFormat": "{{reason}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 24,
        "title": "📈 Background Agent Activity",
        "type": "row",
        "gridPos": {"x": 0, "y": 50, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 25,
        "title": "Background Agent Runs & Suggestions",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 51, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "rate(kagami_background_agent_runs_total[5m])",
            "legendFormat": "Runs - {{agent_type}}",
            "refId": "A"
          },
          {
            "expr": "rate(kagami_background_agent_suggestions_total[5m])",
            "legendFormat": "Suggestions - {{agent_type}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 26,
        "title": "📊 Receipts",
        "type": "row",
        "gridPos": {"x": 0, "y": 59, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 27,
        "title": "Receipt Emission Rate by Phase",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 60, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "sum by (phase) (rate(kagami_receipts_total[5m]))",
            "legendFormat": "{{phase}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80,
              "stacking": {"mode": "normal"}
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "PLAN"},
              "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]
            },
            {
              "matcher": {"id": "byName", "options": "EXECUTE"},
              "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
            },
            {
              "matcher": {"id": "byName", "options": "VERIFY"},
              "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]
            }
          ]
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": {"value": "Prometheus", "text": "Prometheus"}
        }
      ]
    }
  }
}
