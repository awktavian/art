{
  "dashboard": {
    "id": null,
    "uid": "kagami-database-perf",
    "title": "KagamiOS - Database Performance",
    "tags": ["kagami", "database", "cockroachdb", "performance"],
    "timezone": "utc",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Query Latency P95",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(kagami_db_query_duration_seconds_bucket[5m])) by (le, operation))",
            "legendFormat": "{{operation}} P95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(kagami_db_query_duration_seconds_bucket[5m])) by (le, operation))",
            "legendFormat": "{{operation}} P99",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 0,
              "lineWidth": 2
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.1, "color": "yellow"},
                {"value": 0.5, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["mean", "lastNotNull", "max"]
          }
        },
        "alert": {
          "name": "Slow Database Queries",
          "conditions": [
            {
              "evaluator": {"params": [0.1], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "type": "query"
            }
          ],
          "frequency": "1m",
          "handler": 1,
          "noDataState": "no_data",
          "executionErrorState": "alerting"
        }
      },
      {
        "id": 2,
        "title": "Connection Pool Utilization",
        "type": "timeseries",
        "targets": [
          {
            "expr": "(kagami_db_connection_pool_size{state=\"in_use\"} / kagami_db_connection_pool_size{state=\"total\"}) * 100",
            "legendFormat": "Pool Utilization %",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 20,
              "lineWidth": 2
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "red"}
              ]
            },
            "min": 0,
            "max": 100
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "calcs": ["mean", "lastNotNull", "max"]
          }
        },
        "alert": {
          "name": "High Connection Pool Utilization",
          "conditions": [
            {
              "evaluator": {"params": [80], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "type": "query"
            }
          ],
          "frequency": "1m",
          "handler": 1,
          "noDataState": "no_data",
          "executionErrorState": "alerting"
        }
      },
      {
        "id": 3,
        "title": "Transaction Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(kagami_db_query_duration_seconds_count{operation=\"transaction\"}[1m]))",
            "legendFormat": "Transactions/sec",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "lineWidth": 2
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "calcs": ["mean", "lastNotNull"]
          }
        }
      },
      {
        "id": 4,
        "title": "Slow Queries (>100ms)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(kagami_db_query_duration_seconds_bucket{le=\"0.1\",operation!=\"\"}[5m])) by (operation)",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "text": {
            "titleSize": 14,
            "valueSize": 24
          },
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "center",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            },
            "unit": "ops"
          }
        }
      },
      {
        "id": 5,
        "title": "Database Errors",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(kagami_db_query_errors_total[5m])) by (error_type)",
            "legendFormat": "{{error_type}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "lineWidth": 2
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["sum", "lastNotNull"]
          }
        }
      },
      {
        "id": 6,
        "title": "Query Operations Breakdown",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(kagami_db_query_duration_seconds_count[5m])) by (operation)",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "lineWidth": 2,
              "stacking": {
                "mode": "normal"
              }
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["mean", "lastNotNull", "max"]
          }
        }
      },
      {
        "id": 7,
        "title": "Connection Pool State",
        "type": "bargauge",
        "targets": [
          {
            "expr": "kagami_db_connection_pool_size{state=\"in_use\"}",
            "legendFormat": "In Use",
            "refId": "A"
          },
          {
            "expr": "kagami_db_connection_pool_size{state=\"idle\"}",
            "legendFormat": "Idle",
            "refId": "B"
          },
          {
            "expr": "kagami_db_connection_pool_size{state=\"waiting\"}",
            "legendFormat": "Waiting",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "showUnfilled": true,
          "text": {
            "titleSize": 14,
            "valueSize": 20
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 20, "color": "red"}
              ]
            },
            "min": 0
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Waiting"},
              "properties": [
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {"value": 0, "color": "green"},
                      {"value": 1, "color": "red"}
                    ]
                  }
                }
              ]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Query Latency Heatmap",
        "type": "heatmap",
        "targets": [
          {
            "expr": "sum(rate(kagami_db_query_duration_seconds_bucket[5m])) by (le)",
            "legendFormat": "{{le}}",
            "format": "heatmap",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "options": {
          "calculate": false,
          "cellGap": 2,
          "cellRadius": 0,
          "color": {
            "mode": "scheme",
            "scheme": "Spectral"
          },
          "yAxis": {
            "unit": "s"
          }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              }
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Database CPU Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "kagami_system_cpu_usage * 100",
            "legendFormat": "CPU %",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 24},
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "showThresholdLabels": false,
          "showThresholdMarkers": true,
          "text": {
            "titleSize": 16,
            "valueSize": 32
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "red"}
              ]
            },
            "min": 0,
            "max": 100,
            "unit": "percent"
          }
        }
      },
      {
        "id": 10,
        "title": "Database Disk I/O",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(kagami_system_disk_bytes{type=\"read\"}[5m])",
            "legendFormat": "Read",
            "refId": "A"
          },
          {
            "expr": "rate(kagami_system_disk_bytes{type=\"write\"}[5m])",
            "legendFormat": "Write",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 24},
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "lineWidth": 2
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "calcs": ["mean", "max"]
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": {
            "value": "Prometheus",
            "text": "Prometheus"
          }
        },
        {
          "name": "operation",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(kagami_db_query_duration_seconds_count, operation)",
          "multi": true,
          "includeAll": true,
          "current": {
            "value": "$__all",
            "text": "All"
          }
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Database Migrations",
          "datasource": "Prometheus",
          "enable": true,
          "expr": "changes(kagami_db_query_duration_seconds_count{operation=\"migration\"}[1m]) > 0",
          "iconColor": "purple",
          "titleFormat": "DB Migration"
        }
      ]
    }
  }
}
