# Kagami Configuration Template
# Copy to .env and fill in your values

# ============================================================================
# SERVICES (Docker)
# ============================================================================
DATABASE_URL=postgresql://root@localhost:26257/kagami?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# etcd cluster
ETCD_ENDPOINTS=http://localhost:2379,http://localhost:2389,http://localhost:2399
ETCD_CLUSTER_SIZE=3
ETCD_ENABLED=1
ETCD_CONNECT_TIMEOUT=3
ETCD_REQUEST_TIMEOUT=10
KAGAMI_ETCD_REQUIRED=0

# Weaviate (cloud or local)
WEAVIATE_URL=https://your-cluster.weaviate.cloud
WEAVIATE_API_KEY=your-weaviate-api-key

# ============================================================================
# BOOT MODE
# ============================================================================
KAGAMI_BOOT_MODE=full
KAGAMI_FULL_OPERATION=0
LOG_LEVEL=INFO

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
KAGAMI_LLM_PROVIDER=transformers
KAGAMI_BASE_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
KAGAMI_TRANSFORMERS_MODEL_FAST=Qwen/Qwen2-0.5B-Instruct
KAGAMI_TRANSFORMERS_MODEL_DEFAULT=Qwen/Qwen2.5-7B-Instruct
KAGAMI_TRANSFORMERS_MODEL_CODER=Qwen/Qwen3-Coder-30B-A3B-Instruct
KAGAMI_TRANSFORMERS_MODEL_FLAGSHIP=Qwen/Qwen3-Coder-30B-A3B-Instruct
KAGAMI_TRANSFORMERS_MODEL_REASONING=Qwen/Qwen3-Coder-30B-A3B-Instruct
KAGAMI_AUTO_DETECT_MODELS=1
KAGAMI_DEVICE=mps

# ============================================================================
# API KEYS (Required)
# ============================================================================
HF_TOKEN=hf_your_huggingface_token
OPENAI_API_KEY=sk-your-openai-key
GOOGLE_API_KEY=your-google-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEEPSEEK_API_KEY=your-deepseek-key

# ============================================================================
# OPTIONAL API KEYS
# ============================================================================
COMPOSIO_API_KEY=your-composio-key
GOAPI_API_KEY=your-goapi-key
TWOCAPTCHA_API_KEY=your-2captcha-key
PICOVOICE_ACCESS_KEY=your-picovoice-key

# ============================================================================
# AUTONOMOUS EXECUTION
# ============================================================================
KAGAMI_AUTONOMOUS_FULL_EXECUTION=1
KAGAMI_REQUIRE_LLM_REASONING=1
KAGAMI_ENABLE_FILE_MODIFICATIONS=1
KAGAMI_ENABLE_SUBPROCESS=1
KAGAMI_ENABLE_CODE_GENERATION=1
KAGAMI_GOAL_ENGINE_ENABLED=1
KAGAMI_WORLD_MODEL_ENABLED=1
KAGAMI_USE_GEOMETRIC_BRAIN=1

# ============================================================================
# ELYSIA RAG
# ============================================================================
ELYSIA_MEMORY_COLLECTION=KagamiMemory
ELYSIA_FEEDBACK_COLLECTION=ElysiaFeedback
ELYSIA_DEFAULT_MODEL=gemini-1.5-flash
ELYSIA_COMPLEX_MODEL=gemini-1.5-pro
ELYSIA_CBF_ENABLED=true

# ============================================================================
# SECURITY (CHANGE IN PRODUCTION)
# ============================================================================
JWT_SECRET=change-me-in-production
API_KEYS=dev-key-12345
METRICS_PORT=9090

# ============================================================================
# PERFORMANCE
# ============================================================================
REDIS_CONNECT_TIMEOUT=3
DB_CONNECT_TIMEOUT=5
KAGAMI_STATE_DIR=~/.kagami/state
KAGAMI_HAL_PLATFORM=darwin
TRANSFORMERS_VERBOSITY=error

# ============================================================================
# INTEGRATIONS (Optional)
# ============================================================================
KAGAMI_DISABLE_COMPOSIO=0
COMPOSIO_PROVIDER=openai
COMPOSIO_USER_ID=default
ENVISALINK_DISABLED=1

# Figma (optional)
FIGMA_CLIENT_ID=your-figma-client-id
FIGMA_CLIENT_SECRET=your-figma-client-secret

# Slack (optional)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=your-channel-id
SLACK_APP_ID=your-app-id
SLACK_APP_TOKEN=xapp-your-app-token

# Control4 (optional - smart home)
CONTROL4_VERIFY_SSL=0
