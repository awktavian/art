{
  "mcpServers": {
    "peekaboo": {
      "command": "npx",
      "args": ["-y", "@steipete/peekaboo@latest"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/schizodactyl/projects/chronOS",
        "/Users/schizodactyl/projects"
      ]
    },
    "docker": {
      "command": "npx",
      "args": ["-y", "mcp-server-docker"]
    },
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "env": {
        "ALLOW_DANGEROUS": "true",
        "PUPPETEER_LAUNCH_OPTIONS": "{\"headless\": false, \"executablePath\": \"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\", \"userDataDir\": \"/Users/schizodactyl/.kagami/browser-profile\", \"args\": [\"--no-first-run\", \"--no-default-browser-check\", \"--disable-blink-features=AutomationControlled\"]}"
      }
    },
    "everything": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"]
    },
    "canvas": {
      "command": "/bin/sh",
      "args": [
        "-c",
        "CANVAS_API_TOKEN=$(security find-generic-password -s kagami -a canvas_api_token -w) CANVAS_DOMAIN=canvas.instructure.com npx -y canvas-mcp-server"
      ]
    }
  }
}
