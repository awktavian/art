# Kagami Integration Testing Environment Configuration
# These values are used for docker-compose.test.yml integration tests

# Core Test Mode
KAGAMI_TEST_MODE=1
PYTEST_RUNNING=1
KAGAMI_ENV=test
KAGAMI_BOOT_MODE=test

# Service Connection Endpoints (docker-compose.test.yml)
DATABASE_URL=postgresql://root@localhost:26257/kagami_test?sslmode=disable
KAGAMI_DB_URL=postgresql://root@localhost:26257/kagami_test?sslmode=disable
REDIS_URL=redis://localhost:6379/0
KAGAMI_REDIS_URL=redis://localhost:6379/0
WEAVIATE_URL=http://localhost:8081
WEAVIATE_GRPC_HOST=localhost
WEAVIATE_GRPC_PORT=50051
ETCD_ENDPOINTS=http://localhost:2379
ETCD_CLUSTER_SIZE=1
ETCD_ENABLED=1

# Use Real Services (not mocks) for Integration Tests
KAGAMI_USE_REAL_SERVICES=1

# Disable test auto-mocking for integration tests
KAGAMI_TEST_DISABLE_REDIS=0
KAGAMI_DISABLE_ETCD=0

# Security
KAGAMI_API_KEY=test-api-key-integration-0123456789abcdef
WEAVIATE_API_KEY=test-weaviate-key

# Lightweight Models for Fast Testing
KAGAMI_TRANSFORMERS_MODEL_DEFAULT=sshleifer/tiny-gpt2
KAGAMI_TRANSFORMERS_MODEL_CODER=sshleifer/tiny-gpt2
KAGAMI_TRANSFORMERS_MODEL_FAST=sshleifer/tiny-gpt2
KAGAMI_TRANSFORMERS_MODEL_REASONING=sshleifer/tiny-gpt2
KAGAMI_TRANSFORMERS_MODEL_FLAGSHIP=sshleifer/tiny-gpt2
KAGAMI_TRANSFORMERS_MODEL_VISION=sshleifer/tiny-gpt2

# Disable Heavy Components
KAGAMI_LOAD_WORLD_MODEL=0
KAGAMI_LOAD_MATRYOSHKA=0
KAGAMI_DISABLE_VLLM=1

# Performance Tuning
KAGAMI_LLM_TIMEOUT=30
TRANSFORMERS_OFFLINE=0
HF_HUB_OFFLINE=0
TRANSFORMERS_VERBOSITY=error

# Protocol Buffers (etcd3 compatibility)
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

# Logging
LOG_LEVEL=INFO
KAGAMI_LOG_LEVEL=INFO
