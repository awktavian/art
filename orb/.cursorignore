# K os Cursor ignore list
# --------------------------
# Cursor's background indexers were walking heavy binary trees (.venv,
# node_modules, checkpoints, model weights, etc.), inflating memory usage.
# Keep these out of the workspace graph to stabilize boot.

# Version Control
.git/
.svn/
.hg/

# Python virtual environments & tooling caches
.venv/
env/
venv/
.mypy_cache/
.pytest_cache/
.tox/
.hypothesis/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Node/Next.js build artifacts (Deeply nested)
node_modules/
**/node_modules/
kagami/web/app/node_modules/
.next/
**/.next/
kagami/web/app/.next/
.turbo/
**/.turbo/
dist/
**/dist/
build/
**/build/

# Generated coverage + reports
htmlcov/
coverage/
coverage.json
coverage.xml
*.coverage

# Documentation builds
site/
**/site/

# Training artifacts & large model assets
checkpoints/
models/
data/
wandb/
state/
results/
var/
logs/
artifacts/
generated_characters/
style_enforced_output/
.kagami/

# Large binary weight formats
*.pt
*.pth
*.bin
*.safetensors
*.npz
*.npy
*.onnx

# Media files (Video/Audio)
*.mp4
*.mov
*.avi
*.mp3
*.wav

# High-churn logs / traces
*.log
*.trace
*.prof
dump.rdb
*.rdb
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# IDE & Editor Configs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Temporary reports + archives
.archive/

# External repos (third-party clones - not part of K os codebase)
external/
third_party/

# Ignore documentation copies of rules to prevent context pollution
docs/RULE_*.md

# Build info and source maps
*.map
*.tsbuildinfo
*.js.map
*.css.map
