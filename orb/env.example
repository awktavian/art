# env.example
# K os Environment Configuration
# Copy to .env and configure for your environment

# ═══════════════════════════════════════════════════════════════════════════
# CORE SYSTEM
# ═══════════════════════════════════════════════════════════════════════════

# Boot mode: full, test
KAGAMI_BOOT_MODE=full

# Log level
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE & REDIS
# ═══════════════════════════════════════════════════════════════════════════

# CockroachDB / PostgreSQL
DATABASE_URL=cockroachdb://root@cockroachdb:26257/kagami?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════════════════════════════════════
# LLM MODELS
# ═══════════════════════════════════════════════════════════════════════════

# Base model for autonomous reasoning
KAGAMI_BASE_MODEL=Qwen/Qwen2.5-14B-Instruct

# Model tiers
KAGAMI_TRANSFORMERS_MODEL_FAST=Qwen/Qwen2.5-0.5B-Instruct
KAGAMI_TRANSFORMERS_MODEL_DEFAULT=Qwen/Qwen2.5-14B-Instruct

# ═══════════════════════════════════════════════════════════════════════════
# CLOUD API PROVIDERS (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible endpoint
KAGAMI_LLM_API_BASE_URL=
KAGAMI_LLM_API_MODEL=deepseek-ai/DeepSeek-V3

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════

# JWT secret (generate secure value for production)
JWT_SECRET=change-me-in-production

# CSRF token secret
CSRF_SECRET=change-me-in-production

# Cache signing secret
KAGAMI_CACHE_SECRET=change-me-in-production

# Encryption keys (comma-separated Fernet keys)
KAGAMI_ENCRYPTION_KEYS=change-me-in-production

# ═══════════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════════

# Prometheus metrics port
METRICS_PORT=9090

# ═══════════════════════════════════════════════════════════════════════════
# COMPOSIO INTEGRATION (Digital Actuators)
# ═══════════════════════════════════════════════════════════════════════════

# Composio API key from https://app.composio.dev
COMPOSIO_API_KEY=

# Provider (openai, openai_agents)
COMPOSIO_PROVIDER=openai

# User ID for multi-tenant (default: "default")
COMPOSIO_USER_ID=default

# Disable Composio entirely (set to 1 to disable)
KAGAMI_DISABLE_COMPOSIO=0

# ═══════════════════════════════════════════════════════════════════════════
# WEATHER API
# ═══════════════════════════════════════════════════════════════════════════

# OpenWeatherMap API key (free tier: 1000 calls/day)
# Get from https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# PERFORMANCE
# ═══════════════════════════════════════════════════════════════════════════

# Preferred torch device: mps|cuda|cpu (auto-detects if unset)
KAGAMI_DEVICE=

# Bulk dimension for embeddings
KAGAMI_BULK_DIM=512
# Voice / Wake Word Detection
# Get your free access key at: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=
