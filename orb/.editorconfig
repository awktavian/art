# EditorConfig for K os
# =======================
# Ensures consistent coding styles across editors and IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{js,ts,tsx,jsx,json,yaml,yml}]
indent_size = 2

[*.{md,mdc}]
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab

[*.{sh,bash,zsh}]
indent_size = 2

[{package.json,*.yml,*.yaml}]
indent_size = 2

[*.toml]
indent_size = 4

# Docker files
[{Dockerfile,*.dockerfile}]
indent_size = 2

# SQL files
[*.sql]
indent_size = 2
