# Kagami Minimal Configuration
# Copy to .env: cp env.example.minimal .env
#
# This is the minimal config for local development.
# For production settings, see env.example

# ============================================================================
# REQUIRED: None! Kagami runs with sensible defaults.
# ============================================================================

# ============================================================================
# OPTIONAL: Uncomment to customize
# ============================================================================

# Device (auto-detected if unset)
# KAGAMI_DEVICE=cpu          # Force CPU
# KAGAMI_DEVICE=cuda         # Force CUDA GPU
# KAGAMI_DEVICE=mps          # Force Apple Silicon

# Log level
LOG_LEVEL=INFO

# ============================================================================
# SERVICES (only if using Docker)
# ============================================================================

# Redis (default: localhost)
# REDIS_URL=redis://localhost:6379/0

# Database (default: SQLite for dev)
# DATABASE_URL=sqlite:///./kagami.db

# ============================================================================
# LLM (optional - enables autonomous reasoning)
# ============================================================================

# Local model (default - runs on your machine)
# KAGAMI_BASE_MODEL=Qwen/Qwen2.5-14B-Instruct

# Or use an API
# KAGAMI_LLM_API_BASE_URL=http://localhost:8000

# ============================================================================
# For full configuration options, see env.example
# ============================================================================
