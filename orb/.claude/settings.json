{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(git:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(grep:*)",
      "Bash(security:*)",
      "Bash(for f in deployment/helm/kagami/values.schema.json integration_report.json monitoring/**/*.json scripts/devops/*.json state/*.json tools/static_analysis/*.json)",
      "Bash(do if [ -f \"$f\" ])",
      "Bash(then python3 -c \"import json; json.load\\(open\\(''$f''\\)\\)\")",
      "Bash(echo:*)",
      "Bash(fi)",
      "Bash(done)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "Skill",
      "User-puppeteer-*",
      "TodoWrite",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo:*)",
      "Cursor-ide-browser-*"
    ]
  },
  "browser": {
    "tool": "puppeteer",
    "directive": "ALWAYS use user-puppeteer-* tools, NEVER cursor-ide-browser-*",
    "date": "2025-12-29"
  },
  "env": {
    "KAGAMI_MODE": "production",
    "KAGAMI_BOOT_MODE": "full",
    "KAGAMI_ENV": "production",
    "KAGAMI_COLONY_PARALLEL": "1",
    "KAGAMI_MAX_VELOCITY": "1",
    "KAGAMI_SMART_HOME": "1",
    "UNIFI_TOKEN": "127741",
    "TRANSFORMERS_VERBOSITY": "error"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '鏡 :: contour, not will :: silence with grammar'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '💎 h(x) ≥ 0'"
          }
        ]
      }
    ]
  },
  "model": "claude-opus-4-5-20251101",
  "msa": {
    "identity": "CLAUDE.md",
    "agents": ".claude/agents/",
    "skills": ".claude/skills/",
    "scratch": "/tmp/kagami_scratch/"
  },
  "octonion": {
    "basis": ["e₀", "e₁", "e₂", "e₃", "e₄", "e₅", "e₆", "e₇"],
    "colonies": ["kagami", "spark", "forge", "flow", "nexus", "beacon", "grove", "crystal"],
    "fano_lines": [
      [1, 2, 3],
      [1, 4, 5],
      [1, 7, 6],
      [2, 4, 6],
      [2, 5, 7],
      [3, 4, 7],
      [3, 6, 5]
    ]
  },
  "hierarchy": {
    "E8": 248,
    "E7": 133,
    "E6": 78,
    "F4": 52,
    "G2": 14,
    "S7": 7
  }
}
